generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ImplementationStatus {
  PLANNING
  READY
  EXECUTING
  DONE
  PAUSED
}

enum ExecutionStatus {
  SUCCESS
  FAILED
  MANUAL_REQUIRED
  SKIPPED
}

enum DocumentType {
  CALL_TRANSCRIPT
  BRIEF
  FREE_TEXT
  URL
  FILE
}

enum AgentStatus {
  ACTIVE
  DRAFT
}

enum AgentRunStatus {
  PENDING
  RUNNING
  DONE
  ERROR
  ARCHIVED
}

enum AgentOutputType {
  CARDS
  STREAM
  FLOWCHART
  CARDS_AND_FLOWCHARTS
  CARDS_AND_CHARTS
  AUDIT_REPORT
}

enum AgentScope {
  CLIENT
  GLOBAL
}

enum AgentType {
  SECTION // Agente de subetapa — genera cards/flowcharts para una sección
  CANVAS_PROJECT // Agente transversal — actualiza canvas de proyecto
  CANVAS_CLIENT // Agente transversal — actualiza canvas de empresa
  SESSION_PROCESSOR // Agente de procesamiento de sesión — lee Fireflies y genera cards
}

enum ProjectType {
  BASE_IMPLEMENTATION // Implementación base — activación de herramientas, superficial y general
  USE_CASE // Caso de uso — específico y profundo, resolución de un reto particular
}

// El agente de handoff lo infiere (¿el cliente ya usa HubSpot?); el CSE puede corregirlo.
// Define qué plantilla de fases/tareas usa el cronograma (uso futuro). Interno.
enum ImplementationType {
  IMPLEMENTATION // Nueva implementación — el cliente arranca con HubSpot por primera vez
  REIMPLEMENTATION // Re-implementación — ya usa HubSpot o viene de otro CRM
}

enum CardSource {
  AGENT // Generada íntegramente por el agente
  HUMAN // Creada manualmente por el consultor
  MODIFIED // Generada por el agente y luego editada por el consultor
}

enum CardType {
  TEXT // Card de texto (default)
  FLOWCHART // Diagrama de React Flow (nodos + edges guardados en diagramData)
  CHART // Gráfico de ECharts (configuración en chartConfig)
}

// ─── Block system (canvases no-default) ─────────────────────────────────────

enum BlockType {
  TEXT
  HEADING
  TABLE
  METRIC
  CALLOUT
  CARD
  FLOWCHART
  CHART
  IMAGE
}

enum BlockSource {
  AGENT
  HUMAN
  MODIFIED // generado por IA, editado por un humano (CSE)
}

enum BlockStatus {
  DRAFT
  CONFIRMED
}

// ─── Business Cases (Ventas) ─────────────────────────────────────────────────

enum BusinessCaseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BusinessCaseBlockType {
  HERO
  PAIN_POINTS
  BEFORE_AFTER
  SOLUTION
  ROI_METRICS
  TIMELINE
  INVESTMENT
  PARTNER
  CTA
}

enum BusinessCaseTranscriptSource {
  PASTED
  UPLOADED
}

// ─── Client (nueva entidad raíz) ──────────────────────────────────────────────

model Client {
  id               String   @id @default(cuid())
  name             String
  company          String?
  industry         String?
  notes            String?  @db.Text
  hubspotCompanyId String? // ID de la empresa vinculada en HubSpot CRM
  emailDomains     String[] // dominios de email para matching automático de sesiones (ej: "ice.go.cr")
  logoUrl          String? // URL pública del logo del cliente (bucket public-assets) — se muestra en kickoff/cronograma externos
  // Prospecto de Ventas: Client creado lazily desde una empresa HubSpot para un
  // business case (puede no ser cliente real todavía). Se EXCLUYE de los listados
  // de CS (clientes, sidebar, portafolio).
  isProspect       Boolean  @default(false)
  // Procedencia de fuente externa (regla Cobranza fuente + id_externo → upsert
  // idempotente: re-sincronizar NO duplica). null = creado por flujos previos.
  source           String? // "manual" | "sheet" (futuro: "hubspot" | "odoo")
  sourceExternalId String? // id estable en la fuente (columna id del sheet o slug del nombre)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  canvas           Json? // Client Canvas — conocimiento a nivel empresa
  canvasConfidence Json? // { section: "confirmed" | "inferred" } per section

  hubspotAccount    HubspotAccount?
  audits            Audit[]
  implementations   Implementation[]
  knowledge         Knowledge[]
  documents         ClientDocument[]
  stageNotes        StageNote[]
  agentRuns         AgentRun[]
  contextCards      ClientContextCard[]
  projects          Project[]
  canvasSuggestions CanvasSuggestion[]
  actionItems       ActionItem[]
  appUsers          AppUser[] // F2: usuarios externos vinculados (kind=EXTERNAL)
  assignments       ClientAssignment[] // F2: overrides manuales CSE↔Cliente
  handoffs          Handoff[] // entidad Handoff (1:N por cliente, ver model Handoff)
  businessCases     BusinessCase[] // Ventas: casos de negocio (1:N por cliente)
  csAlerts          CsAlert[] // Éxito del cliente: alertas del watchdog
  csSignals         ClientCsSignals? // Éxito del cliente: snapshot de señales HubSpot
  partnerSnapshot   ClientPartnerSnapshot? // CS360: snapshot del objeto Partner Clients de HubSpot
  accountBrief      CsAccountBrief? // CS360: resumen ejecutivo citado (agente)
  cuentaFinanciera  CuentaFinanciera? // Cobranza: perfil de cobro 1:1 (ver sección Cobranza)
  importFilasAplicadas ImportacionFila[] // Cobranza: trazabilidad del importador

  @@unique([source, sourceExternalId]) // NULLs no colisionan en Postgres — los legacy conviven
}

// ─── SystemConfig (config GLOBAL de Nexus, singleton — no por usuario) ─────────
// Un solo row (id="system"; se upsert). Hoy guarda el logo de Smarteam
// configurable (se muestra en el chrome externo, con fallback a /logo-smarteam.png).
model SystemConfig {
  id              String   @id @default("system")
  smarteamLogoUrl String? // URL pública del logo de Smarteam (bucket public-assets)
  hubspotLogoUrl  String? // logo de HubSpot — brand-row de business cases + kickoffs
  insiderLogoUrl  String? // logo de Insider One — ídem
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Project ──────────────────────────────────────────────────────────────────

model Project {
  id                 String              @id @default(cuid())
  clientId           String
  client             Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name               String
  status             String              @default("active") // active | paused | completed
  projectType        ProjectType         @default(USE_CASE) // Tipo de proyecto: implementación base o caso de uso
  implementationType ImplementationType? // ¿nueva impl o re-impl? Lo infiere el handoff; el CSE corrige. Interno (no cruza al cliente).
  serviceType        String? // loop_marketing | loop_sales | loop_service | proyecto_temporal
  hubspotDealId      String? // ID del deal de HubSpot asociado a este proyecto
  hubspotServiceId   String?             @unique // ID del objeto Service en HubSpot (para sync)
  currentStage       Int                 @default(1) // Última etapa visitada/modificada (1-3)
  currentStep        Int                 @default(0) // Último paso visitado/modificado dentro de la etapa (0-indexed)
  canvas             Json? // DEPRECATED — ya no se lee para renderizar el canvas
  tags               String[]            @default([]) // Tags generales del proyecto (e.g. "Marketing Hub", "Sales Hub")
  shareToken         String?             @unique // Token para vista pública del cliente

  // GPS del proyecto
  nextSessionDate    DateTime? // LEGACY (project-wide) — reemplazado por los overrides por frente de abajo
  nextSessionNote    String? // LEGACY (project-wide)
  lastSessionSummary String?   @db.Text // LEGACY — resumen manual de la última sesión (el widget ya no lo edita)
  pendingItems       Json? // Array de { text: string, done: boolean }

  // Override manual de la PRÓXIMA sesión POR FRENTE — para reuniones "ajenas a meets"
  // (no capturadas por el sync de Google Workspace). El widget GPS muestra dos frentes
  // (Ventas / CS); si hay override manual para un frente, precede al auto-detectado.
  salesNextSessionDate DateTime? // Próxima sesión de VENTAS agendada a mano
  salesNextSessionNote String? // Nota de la próxima sesión de ventas
  csNextSessionDate    DateTime? // Próxima sesión de CS (entrega de servicio) agendada a mano
  csNextSessionNote    String? // Nota de la próxima sesión de CS

  // El handoff (agente que analiza las llamadas de ventas) CORRIÓ y clasificó este
  // proyecto. Compuerta del ciclo de vida (lib/lifecycle): sin handoff generado, el
  // portal CS no muestra etapas — solo un aviso. La recurrencia (tag `recurrente`) y
  // la etapa solo son confiables cuando esto != null. Lo sella persistTimelineFromAgentOutput.
  handoffGeneratedAt DateTime?

  // Fase C — publish del Kickoff al cliente externo. Acción SEPARADA del acceso:
  // null = no publicado (el cliente, aunque tenga credenciales, no ve el Kickoff);
  // fecha = publicado. El chokepoint externo (lib/external/kickoff-view.ts) exige
  // que esto NO sea null en CADA lectura, así despublicar corta el acceso al instante.
  kickoffPublishedAt DateTime?

  // D.1.5 — publish del CRONOGRAMA al cliente externo. Regla UNIFICADA: gobierna
  // el cronograma donde sea que aparezca (página /external/cronograma Y la sección
  // embebida en el kickoff). Independiente de kickoffPublishedAt — una superficie
  // puede estar publicada sin la otra. Chequeado en CADA lectura por los chokepoints.
  timelinePublishedAt DateTime?

  // Publish del canvas DESARROLLO (requerimiento técnico) a un DEV externo. Mismo
  // patrón que kickoffPublishedAt: null = no compartido; fecha = compartido. GATE de
  // SEGURIDAD load-bearing — el token de acceso externo es POR PROYECTO y se comparte
  // también con el CLIENTE (para el kickoff), así que sin este flag el cliente vería el
  // requerimiento técnico interno. El chokepoint (lib/external/desarrollo-view.ts) lo
  // exige NO-null en cada lectura; despublicar corta el acceso al instante.
  desarrolloPublishedAt DateTime?

  // #3 — visibilidad de secciones/procesos en el kickoff del cliente, por proyecto.
  // hiddenKickoffKeys = claves OCULTAS del kickoff. Una clave puede ser:
  //   · el id de una CanvasSection del kickoff → oculta esa sección de contenido,
  //   · "cronograma" → oculta la sección de cronograma embebida (independiente del
  //      publish del cronograma standalone, timelinePublishedAt),
  //   · "procesos" → oculta toda la sección de procesos,
  //   · el id de un flowchart de proceso → oculta ESE proceso.
  // El chokepoint (lib/external/kickoff-view.ts) filtra por este set. Reversible, no borra datos.
  hiddenKickoffKeys         String[] @default([])
  // Legacy — reemplazado por hiddenKickoffKeys (se mantiene la columna por compat; sin uso en código).
  procesosHiddenFromKickoff Boolean  @default(false)

  // Asignación franja→sesión de "Sesiones y horarios" del kickoff: { [sessionId]: optionId | null }.
  // Es COORDINACIÓN, no contenido: como hiddenKickoffKeys, es un overlay VIVO que modula lo que ve
  // el cliente por encima del publishedSnapshot congelado. Lo escriben las DOS puntas — el CSE desde
  // Nexus y el cliente desde su página (server action, auto-save) — y ninguna necesita "Subir al
  // cliente". La DEFINICIÓN de franjas y sesiones sigue viviendo en el bloque CARD de la sección.
  // null = overlay sin sembrar → se migra perezosamente desde los `sessions[].optionId` del bloque.
  kickoffHorarioAssignments Json?

  // Propiedades sincronizadas desde HubSpot (objeto Service)
  hubspotOwnerId      String? // hubspot_owner_id (ID del owner en HubSpot)
  hubspotOwnerName    String? // Nombre del owner (CSE encargado) resuelto desde /owners/{id}
  hubspotOwnerEmail   String? // Email del owner
  hubspotCreatedAt    DateTime? // hs_createdate del servicio en HubSpot
  hubspotPipelineName String? // Nombre del pipeline resuelto desde hs_pipeline

  // D.2 — etapa actual del pipeline de Customer Success (híbrido: materializada acá
  // por sync-projects y revalidada en vivo al disparar la regeneración del cronograma).
  // El label es lo que el agente de avance razona (ancla #1); el id permite comparar.
  hubspotPipelineStageLabel String? // label legible de hs_pipeline_stage (p.ej. "Onboarding")
  hubspotPipelineStageId    String? // id de la etapa (hs_pipeline_stage) para comparar/revalidar
  hubspotStageSyncedAt      DateTime? // última vez que se materializó/revalidó la etapa

  // CS360 — propiedades operativas del 0-970 para el dashboard de la CSL (valores
  // CRUDOS de HubSpot; el mapeo a labels ES vive en lib/cs). null = sin valor en HS.
  hubspotPriority      String? // hs_priority: low | medium | high
  hubspotStatus        String? // hs_status: on_track | delayed | blocked | completed | on_hold | at_risk
  hubspotBlockReason   String? // motivo_de_bloqueo (label del enum radio, 7 valores)
  hubspotBlockDetail   String? @db.Text // detalle_del_motivo_de_bloqueo (Desarrollo, fallback Implementaciones)
  hubspotAdoptionState String? // estado_de_adopcion: No iniciado | Bajo | Medio | Alto

  // D.3 panel — SALUD del proyecto, HÍBRIDA: el panel de cartera PROPONE una salud derivada
  // de señales (atrasos/inactividad/firmeza) calculada al vuelo en lib/portfolio; este override
  // es la versión CURADA por CSL/Ventas/SA. Si hay override prevalece; null = se usa la derivada.
  healthStatusOverride       ProjectHealth?
  healthStatusOverrideReason String? // por qué el humano fijó este estado
  healthStatusOverrideAt     DateTime? // cuándo
  healthStatusOverrideBy     String? // email de quien lo fijó (del guard)

  // Ciclo de vida (lib/lifecycle) — la etapa EFECTIVA = override ?? inferida por el
  // motor al vuelo (NO se materializa, igual que la salud derivada). Override = curación
  // del CSE (mismo patrón que healthStatusOverride).
  lifecycleStageOverride       ProjectLifecycleStage?
  lifecycleStageOverrideReason String?
  lifecycleStageOverrideAt     DateTime?
  lifecycleStageOverrideBy     String? // email de quien lo fijó (del guard)
  lifecycleCycle               String? // "full" | "short" — null = inferido de serviceType/projectType
  // Modalidad de adopción (etapa ADOPCION): el sistema SUGIERE por el tamaño de la
  // cuenta (snapshot Partner de HubSpot), el CSE confirma. null = sin confirmar.
  adoptionMode                 String? // "directa" | "por_pilotos" (confirmada)
  adoptionModeConfirmedAt     DateTime?
  adoptionModeConfirmedBy     String?
  isSuccessCase                Boolean   @default(false) // flag "Caso de éxito" al FINALIZAR
  // Estado EN_RIESGO PROPUESTO (eje de Estado: el agente PROPONE, el CSE confirma).
  // Confirmar = escribir healthStatusOverride=EN_RIESGO y limpiar esto; descartar =
  // limpiar. Si la señal desaparece, el watchdog lo limpia solo (caduca).
  healthProposed          ProjectHealth?
  healthProposedReason    String?   @db.Text
  healthProposedAt        DateTime?
  healthProposedByRunId   String? // AgentRun del watchdog que lo propuso (trazabilidad)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stageNotes          StageNote[]
  contextCards        ClientContextCard[]
  documents           ClientDocument[]
  agentRuns           AgentRun[]
  canvases            ProjectCanvas[]
  actionItems         ActionItem[]
  sessions            SessionProject[]
  participantSnapshot ProjectParticipantSnapshot?
  externalAccess      ProjectExternalAccess?
  timeline            ProjectTimeline?
  handoff             Handoff?
  handoffSources      HandoffSource[]
  timelineEvents      TimelineEvent[] // Éxito del cliente: eventos crudos del cronograma
  csAlerts            CsAlert[] // Éxito del cliente: alertas del watchdog
  serviciosCobranza   ServicioContratado[] // Cobranza: servicios facturables ligados a este proyecto
  stageGates          ProjectStageGate[] // Ciclo de vida: validaciones de salida cumplidas
}

// D.3 panel — salud del proyecto para el panel de cartera. Es el OVERRIDE curado; la salud
// derivada (automática) se calcula al vuelo en lib/portfolio a partir de las señales de riesgo.
// PAUSADO espeja el caso Project.status="paused".
enum ProjectHealth {
  SALUDABLE
  EN_FRICCION
  EN_RIESGO
  PAUSADO
}

// ─── Ciclo de vida del proyecto (lib/lifecycle) ───────────────────────────────
// Fuente de verdad: Nexus. La etapa NO se materializa: se INFIERE al vuelo de los
// gates cumplidos (cascada en lib/lifecycle/stage-engine.ts) y el CSE puede pisarla
// con Project.lifecycleStageOverride. Slugs ESTABLES: son el internal value de la
// futura propiedad de HubSpot (sync bidireccional) — NO renombrar.
// Distinto de TimelineActivityType (tipos de actividad del Gantt) y de
// Project.currentStage (navegación del editor 1-3).
enum ProjectLifecycleStage {
  HAND_OFF // Ventas transfiere; sale cuando el kickoff se publica (kickoffPublishedAt)
  EXPLORACION // entender el negocio; sale con ENTENDIMIENTO_CERRADO
  DIAGNOSTICO // entregable de valor; sale con DIAGNOSTICO_COMPARTIDO
  PLANIFICACION // arquitectura + cronograma; sale con CRONOGRAMA_CONSENSUADO
  CONFIGURACION_TECNICA // construcción sobre HubSpot; sale con DEMO_APROBADA
  ADOPCION // directa o por pilotos (adoptionMode); sale con CLIENTE_OPERANDO
  VALIDACION_USO // sale con USO_VALIDADO (UUS >= umbral, o CSE)
  ENTREGA // cierre formal + handoff comercial; sale con ENTREGA_REALIZADA
  OPERACION_CONTINUA // ciclo corto (continuidad/soporte/bolsa de horas)
  FINALIZADO // cierre; isSuccessCase marca "Caso de éxito"
}

// Validaciones de SALIDA de cada etapa ("lo que mueve la tarjeta"). La salida de
// HAND_OFF no necesita gate: es Project.kickoffPublishedAt (señal dura existente).
enum ProjectStageGateKey {
  ENTENDIMIENTO_CERRADO // salida EXPLORACION (CSE marca; señal blanda: sesión + minuta REVIEWED)
  DIAGNOSTICO_COMPARTIDO // salida DIAGNOSTICO (CSE marca; señal: canvas "Diagnóstico" con bloques)
  CRONOGRAMA_CONSENSUADO // salida PLANIFICACION (v1: CSE marca cuando el cliente aprueba)
  DEMO_APROBADA // salida CONFIGURACION_TECNICA (CSE marca)
  CLIENTE_OPERANDO // salida ADOPCION (CSE marca; señales: sesiones adopción + hubspotAdoptionState)
  USO_VALIDADO // salida VALIDACION_USO (sistema: UUS >= umbral; o CSE)
  ENTREGA_REALIZADA // salida ENTREGA (CSE marca; note lleva la sugerencia para Ventas)
}

// Gate cumplido = EVENTO duro con fecha + quién + origen (tabla, no JSON: unicidad
// por proyecto+gate, queryable para backfill/motor batch, reversible por DELETE).
model ProjectStageGate {
  id        String              @id @default(cuid())
  projectId String
  project   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  gate      ProjectStageGateKey
  markedAt  DateTime            @default(now())
  markedBy  String? // email del CSE; null = sistema
  source    String              @default("cse") // "cse" | "system" | "backfill"
  note      String?             @db.Text // p.ej. sugerencia de cross-selling en ENTREGA_REALIZADA
  evidence  Json? // { sessionId?, canvasId?, uusScore? } — drill a la señal que lo justificó

  @@unique([projectId, gate])
  @@index([projectId])
}

// ─── Handoff (entidad cliente-level) ──────────────────────────────────────────
// Un handoff nace cuando se gana un deal: lleva la info de ventas a CS y arranca el
// proyecto. 1:N bajo el Client (un cliente acumula varios en el tiempo), 1:1 con un
// Project y con el deal ancla. Su CONTENIDO vive en el canvas "Handoff" del Project
// (1:1) — no se duplica acá. El sync a HubSpot (crear el record "projects" + propiedad
// en la company) es aparte y eventual; lo gobierna hubspotSyncStatus.
model Handoff {
  id            String  @id @default(cuid())
  clientId      String
  client        Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId     String  @unique // 1:1 con el Project (su contenido = canvas "Handoff" del project)
  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  hubspotDealId String? @unique // deal ancla de HubSpot (1 handoff por deal)

  // Sync a HubSpot (eventual + reintentable; ver decisión #2 del plan)
  hubspotProjectId       String? // id del record "projects" creado en HubSpot (post-sync)
  hubspotSyncStatus      String  @default("pending") // pending | synced | failed
  hubspotSyncError       String? @db.Text
  // Owner de HubSpot a setear en el record "projects" SOLO cuando el sync lo CREA de
  // cero (handoff nacido del stepper de ventas). null = sin owner forzado (handoffs
  // viejos / generados in-project). Se aplica una sola vez, en CASO B del sync.
  hubspotOwnerIdOnCreate String?

  generatedByAgentRunId String? // trazabilidad de la corrida del agente de handoff

  // Exclusiones de contexto del CSE (texto libre, ej. "ignorá el proyecto DocuSign").
  // Se inyectan como reglas negativas duras en el prompt del agente de handoff.
  contextExclusions String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

// ─── HandoffSource — fuente MANUAL del handoff (transcript/resumen pegado a mano) ──
// Para reuniones que NO entraron por el sync de Google Workspace (ej. un Zoom ajeno):
// ventas pega el transcript/resumen y el agente de handoff lo usa como UNA fuente más,
// ETIQUETADA como manual (distinta de las sesiones verificadas del sync). Keyed por
// projectId (el handoff es 1:1 con el project; persiste aunque el Handoff aún no exista
// o se recree → reproducible/auditable). El analyze la re-lee en CADA corrida, así una
// regeneración la vuelve a incluir. SOLO la lee el path de handoff; NO se muestra en el
// tab Documentos ni alimenta a otros agentes.
model HandoffSource {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String? // etiqueta opcional para identificarla
  content        String    @db.Text // el texto pegado (transcript/resumen)
  kind           String    @default("manual") // futuro-proof: otros tipos de fuente manual
  createdByEmail String? // quién la pegó (del guard de sesión)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime? // soft-delete (auditable; el read filtra deletedAt:null)

  @@index([projectId, createdAt])
}

// ─── ProjectTimeline + TimelinePhase ──────────────────────────────────────────
// Cronograma estructurado del proyecto (Fase 2 del módulo externo).
//
// Lo propone el agente "Handoff Sales→CS" a partir de las transcripciones de
// ventas (donde típicamente se acuerda la secuencia: "kick-off + arquitectura
// + 6 sesiones de set up + 6 de onboarding, 10 semanas total"). El CSE lo
// edita libremente. Las fases tienen duración en SEMANAS, sin fechas concretas
// — el `anchorStartDate` (opcional) es el ancla; las fechas reales del landing
// se calculan en runtime como `anchorStartDate + sum(durationWeeks_anteriores) * 7 días`.
//
// Patrón de re-ejecución: el agente solo crea el cronograma si NO existe. Si
// ya hay uno, la nueva propuesta queda en AgentRun.output (trazabilidad) pero
// no se aplica — para regenerar, el CSE borra explícitamente y vuelve a correr.

model ProjectTimeline {
  id                          String    @id @default(cuid())
  projectId                   String    @unique
  project                     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  anchorStartDate             DateTime? // null hasta que el CSE la fije; cuando exista, define la conversión semanas → fechas
  lastEditedByHuman           DateTime? // se actualiza en cada PUT que toca fases (no en el create del agente)
  // D.3 staging — el cliente ve SOLO este SNAPSHOT (shape client-safe de readClientTimeline)
  // congelado al "Subir". La vista externa NUNCA lee en vivo: si está publicado y el snapshot
  // es null (timeline pre-D.3), readPublishedClientTimeline hace un backfill perezoso (congela
  // el vivo actual una vez); si no hay timeline, devuelve vacío (fail-closed).
  publishedSnapshot           Json?
  generatedByAgentRunId       String? // de qué AgentRun salió la propuesta inicial (trazabilidad)
  generatedByAgentRun         AgentRun? @relation(fields: [generatedByAgentRunId], references: [id], onDelete: SetNull)
  // D.1 — cronograma detallado:
  detailConfirmedAt           DateTime? // gate de la vista cliente: las tareas solo cruzan al kickoff externo si != null
  detailGeneratedByAgentRunId String? // de qué AgentRun salió el detalle (tareas/tipos) — trazabilidad
  detailGeneratedByAgentRun   AgentRun? @relation("TimelineDetailGenerator", fields: [detailGeneratedByAgentRunId], references: [id], onDelete: SetNull)
  // Re-generación en proyectos en curso: cuando el agente re-deriva un cronograma y YA existe uno,
  // la propuesta NO se aplica (protege ediciones/progreso) — se guarda acá, reconciliada al shape del
  // PUT (fases con id existente cuando matchean, SIN `tasks` para preservar el detalle), y el canvas
  // la muestra como vista previa aplicable. null = sin propuesta pendiente. Se limpia al aplicar/descartar.
  pendingProposal             Json?
  pendingProposalRunId        String? // AgentRun del que salió la propuesta pendiente (trazabilidad)
  // D.2 — BORRADOR DE AVANCE (hermano de pendingProposal; NO se mezcla). El agente de
  // avance detecta qué fases/tareas están hechas y dónde cae el "hoy", y lo guarda acá
  // SIN tocar status (eso lo confirma el CSE). Shape: { currentPhaseId, asOfSessionId,
  // reasoning, phases:[{id,done}], tasks:[{id,done}] }. Se reemplaza en cada corrida;
  // se limpia al aplicar (timeline/progress/apply) o descartar (DELETE timeline/progress).
  pendingProgress             Json?
  pendingProgressRunId        String? // AgentRun del que salió el borrador de avance (trazabilidad)
  // Particularidades — BORRADOR (hermano de pendingProgress, NO se mezcla). El agente de avance
  // propone desviaciones curadas (atraso/solicitud/compromiso) del transcript; el CSE acepta ítem
  // por ítem en el banner y recién ahí se crean las filas Particularidad. Se limpia al aplicar
  // (timeline/particularidades/apply) o descartar. Shape: { reasoning, items:[{kind,party,title,detail,weeksImpact}] }.
  pendingParticularidades     Json?
  pendingParticularidadesRunId String? // AgentRun del que salió el borrador de particularidades
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  phases          TimelinePhase[]
  changes         TimelineChange[] // #4 — historial de ediciones (razón + snapshot) para D.3
  baselines       TimelineBaseline[] // D.3 — baselines "vendidos" congelados al publicar (versionados)
  particularidades Particularidad[] // desviaciones curadas (atribución cliente/Smarteam), cara al cliente

  @@index([projectId])
}

model TimelinePhase {
  id              String                @id @default(cuid())
  timelineId      String
  timeline        ProjectTimeline       @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  name            String // "Kick-off", "Arquitectura", etc.
  order           Int // 0-indexed, posición en la secuencia
  durationWeeks   Int                   @default(1) // 1+
  // Inicio EXPLÍCITO (offset 0-based desde anchorStartDate). null = contigua tras la fase anterior
  // (comportamiento por defecto). Habilita fases EN PARALELO (dos con el mismo inicio se solapan):
  // típico, una integración/desarrollo que corre en paralelo a la implementación del hub.
  startWeek       Int?
  sessionCount    Int? // opcional — algunas fases no son por sesiones
  notes           String?               @db.Text // texto libre opcional (contexto editable)
  activityType    TimelineActivityType? // D.1: tipo de actividad (nullable — fases pre-D.1 quedan sin tipo, render neutro)
  source          TimelinePhaseSource   @default(AGENT)
  // El agente del handoff marca true cuando ESTIMÓ la fase/duración sin dato real en ventas
  // (badge "estimada" + banner). Se limpia cuando el CSE edita la fase (PUT). Interno — NO cruza al cliente.
  needsValidation Boolean               @default(false)
  // D.2 — avance a nivel fase (reusa el enum de tarea). DONE = fase completada;
  // IN_PROGRESS = la fase en curso (el "hoy"); PENDING = por delante. Lo escribe SOLO
  // el CSE (mismo invariante que TimelineTask.status); el agente lo PROPONE en pendingProgress.
  status          TimelineTaskStatus    @default(PENDING)
  // Procedencia del ESTADO actual (ortogonal a `source`, que describe el CONTENIDO): HUMAN = lo
  // resolvió el CSE a mano; AI_CONFIRMED = el detector de avance lo detectó y el CSE lo confirmó en
  // el banner. Hace explícito el invariante que antes era implícito ("status != PENDING ⟹ humano").
  statusSource        TimelineStatusSource @default(HUMAN)
  statusChangedByEmail String?
  statusChangedAt      DateTime?
  // D.3 fundación — fechas REALES de ejecución, MONÓTONAS (no se auto-borran):
  // actualStart la 1ra vez que va a IN_PROGRESS/DONE; actualEnd al DONE. Volver a
  // PENDING/IN_PROGRESS NO las borra — el status manda para "¿hecho hoy?", las fechas son histórico.
  actualStart     DateTime?
  actualEnd       DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  tasks            TimelineTask[]
  particularidades Particularidad[] // desviaciones ancladas a esta fase (opcional; SetNull al borrar la fase)

  @@index([timelineId, order])
}

// D.1 — tarea de una fase del cronograma. weekIndex es RELATIVO a la fase
// (0-indexed, rango [0, durationWeeks)); en UI se muestra 1-based.
// El estado vive separado del contenido a propósito: D.2 podrá regenerar
// contenido preservando estados humanos por id. Invariante D.1: el agente
// solo crea PENDING → todo status != PENDING es humano por definición. `statusSource`
// hace ese invariante EXPLÍCITO y auditable por-tarea (ver TimelinePhase.statusSource).
model TimelineTask {
  id                String              @id @default(cuid())
  phaseId           String
  phase             TimelinePhase       @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  title             String
  weekIndex         Int // 0-indexed, relativo a la fase
  order             Int                 @default(0) // orden dentro de la semana
  status            TimelineTaskStatus  @default(PENDING)
  // Procedencia del ESTADO (ver TimelinePhase.statusSource): HUMAN = check manual del CSE;
  // AI_CONFIRMED = avance detectado por IA y confirmado por el CSE en el banner.
  statusSource        TimelineStatusSource @default(HUMAN)
  statusChangedByEmail String?
  statusChangedAt      DateTime?
  // #4 — override manual de fechas por tarea. INTENCIÓN: cuando estén seteadas deben
  // ganar sobre la fecha DERIVADA de la semana (anchor + offset de fase + weekIndex) y
  // cruzar al cronograma compartible como fecha efectiva. Se editan con datepicker en el
  // drawer (chip "manual"). ESTADO: se PERSISTEN, pero el consumo en el render (Gantt
  // interno + vista externa) está PENDIENTE — hoy ningún render prefiere el override sobre
  // la fecha derivada. null = derivar (default).
  startDateOverride DateTime?
  dueDateOverride   DateTime?
  // D.3 fundación — fechas REALES de ejecución (ver TimelinePhase).
  actualStart       DateTime?
  actualEnd         DateTime?
  notes             String?             @db.Text
  needsValidation   Boolean             @default(false) // tarea típica inventada por el agente con handoff flaco — el Gantt la grita; NUNCA cruza al cliente
  // B — dueño de la tarea en el plan de alineación compartido. CLIENTE entrega/hace;
  // SMARTEAM configura; AMBOS trabajo conjunto. Nullable = sin asignar (data pre-B).
  // Cruza al cronograma compartible del cliente (gated por "Subir"); el Kickoff embebido NO lo muestra.
  party             TaskParty?
  // ¿la tarea es una SESIÓN (reunión con el cliente) o una TASK (acción/entregable)?
  // Nullable = sin tipar (efectivo = TASK). Cruza al cronograma compartible SOLO si es SESSION.
  // Mapeo a futuro (NO se sincroniza hoy): SESSION → HubSpot Meeting (0-47); TASK → HubSpot Task (0-27).
  type              TimelineTaskType?
  source            TimelinePhaseSource @default(AGENT) // reuso consciente del enum (mismo ciclo AGENT→MODIFIED/HUMAN); renombrarlo = recrear tipo en PG por cero ganancia
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([phaseId, weekIndex, order])
}

enum TimelinePhaseSource {
  AGENT // generada por la IA, sin tocar humano
  MODIFIED // generada por IA, editada por humano (al pasar por PUT con id existente)
  HUMAN // creada desde cero por humano (PUT con phase sin id)
}

// Procedencia del ESTADO (status) de una fase/tarea — distinto de `source` (procedencia del
// CONTENIDO). El detector de avance NUNCA escribe status directo: todo estado terminal nace de
// una acción humana, sea directa (HUMAN) o confirmando una detección de IA en el banner (AI_CONFIRMED).
enum TimelineStatusSource {
  HUMAN // el CSE resolvió el estado a mano (check/desmarcado directo)
  AI_CONFIRMED // el avance lo detectó la IA y el CSE lo confirmó (botón "Aplicar avance")
}

// B — dueño de una tarea del cronograma, desde la óptica del plan compartido con el cliente.
enum TaskParty {
  CLIENTE // lo entrega o hace el cliente (insumos: documentación, bases, listados, accesos)
  SMARTEAM // configuración técnica en HubSpot (pipeline, propiedades, automatizaciones, integraciones)
  AMBOS // trabajo conjunto (sesiones, talleres, validaciones, onboarding, seguimiento)
  DEV // #7 — desarrollo/integración (equipo técnico). Tareas de la fase "Desarrollo / Integración".
}

// Tipo de tarea del cronograma. Mapea a futuro (sin sync hoy):
// SESSION → HubSpot Meeting (objeto 0-47); TASK → HubSpot Task (objeto 0-27, hs_task_type=TODO).
enum TimelineTaskType {
  SESSION // reunión / sesión de trabajo con el cliente (kickoff, revisión, demo, capacitación)
  TASK // acción / entregable / configuración (no es una reunión)
}

// PARTICULARIDAD — desviación CURADA del cronograma, con atribución (¿quién la causó?).
// El propósito: exponerle al cliente POR QUÉ y QUIÉN movió el cronograma, sin mostrarle el log
// de auditoría crudo (TimelineChange, cuyos `reason` son autogenerados = ruido de máquina).
// Scoped al timeline (mismo cascade/lifecycle que TimelineChange/TimelineBaseline). El CSE la
// crea a mano o acepta una propuesta del agente; solo cruza al cliente si visibleExternal=true.
model Particularidad {
  id              String               @id @default(cuid())
  timelineId      String
  timeline        ProjectTimeline      @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  phaseId         String? // ancla opcional a una fase; SetNull para no perder la particularidad al borrar la fase
  phase           TimelinePhase?       @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  kind            ParticularidadKind
  party           TaskParty // reusa el enum de tarea (CLIENTE/SMARTEAM/AMBOS/DEV) — misma atribución/chips
  title           String // corto, en lenguaje cliente
  detail          String?              @db.Text
  sourceQuote     String?              @db.Text // cita interna que respalda el hecho ([fecha] «fragmento»); NUNCA cruza al cliente
  weeksImpact     Int? // semanas de corrimiento que causó; null si no movió fechas
  visibleExternal Boolean              @default(false) // gate por-registro; se respeta en el chokepoint (como SUSPENDED)
  source          ParticularidadSource @default(HUMAN)
  needsValidation Boolean              @default(false) // true mientras es propuesta del agente sin confirmar
  createdByEmail  String? // quién la creó/confirmó (del guard)
  occurredAt      DateTime             @default(now()) // cuándo ocurrió la desviación (editable; default = ahora)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([timelineId, occurredAt])
  @@index([timelineId, visibleExternal])
}

// Tipo de particularidad de cara al cliente:
enum ParticularidadKind {
  ATRASO // algo se atrasó (weeksImpact OBLIGATORIO en creación/edición nueva; una party responsable)
  SOLICITUD // @deprecated — insumo del cliente = tarea party=CLIENTE, no particularidad. Ya no se propone/crea; se conserva por filas legacy (fallback de render). Ver docs/DECISIONS.md (eje DESTINO).
  COMPROMISO // un acuerdo/hito comprometido en una sesión que fija/mueve una fecha del plan
}

// Procedencia de la particularidad (distinto de `party`, que es la ATRIBUCIÓN de la causa).
enum ParticularidadSource {
  AGENT // propuesta por el agente de avance y confirmada por el CSE
  HUMAN // creada a mano por el CSE
}

// #4 — historial de cambios del cronograma. Cada edición lleva una razón OBLIGATORIA
// y guarda un snapshot del estado resultante (no es un log efímero) para que D.3 pueda
// comparar el cronograma "vendido" (primer snapshot) contra el "real" (último) y
// explicar los desvíos con su motivo.
model TimelineChange {
  id             String             @id @default(cuid())
  timelineId     String
  timeline       ProjectTimeline    @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  reason         String             @db.Text // obligatoria — el "por qué" del cambio
  kind           TimelineChangeKind @default(MANUAL)
  instruction    String?            @db.Text // si kind=AI_ASSIST, la instrucción dada al asistente
  changedByEmail String? // quién hizo el cambio (del guard de sesión)
  snapshot       Json // estado resultante: { anchorStartDate, phases:[{...,tasks:[...]}] }
  createdAt      DateTime           @default(now())

  @@index([timelineId, createdAt])
}

enum TimelineChangeKind {
  MANUAL // edición manual del CSE ("Guardar cronograma")
  AI_ASSIST // aplicada desde una propuesta del asistente de IA
  PROGRESS // D.3 — confirmación de avance (D.2): registra qué se marcó y quién (delta compacto, sin snapshot completo)
  REANCHOR // ciclo de vida — re-anclaje automático al Kick Off real (reason lleva el before; reversible en el Gantt)
}

// D.3 fundación — BASELINE "vendido" congelado al PUBLICAR el cronograma al cliente.
// Snapshot prístino e independiente de si el CSE editó a mano: es la promesa contra la
// que D.3 (después) compara lo ejecutado. Versionado: cada publish con estructura distinta
// crea una versión nueva (isActive=true) y desactiva la anterior — se conservan todas.
// El snapshot incluye fechas planeadas por ítem + needsValidation + source para que las
// alarmas distingan "te desviaste de algo firme" de "de un relleno del agente".
model TimelineBaseline {
  id               String          @id @default(cuid())
  timelineId       String
  timeline         ProjectTimeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  version          Int // 1, 2, 3… (max+1 por timeline)
  isActive         Boolean         @default(true) // la última publicada; D.3 compara contra esta
  anchorStartDate  DateTime? // ancla al momento de congelar
  snapshot         Json // estructura frozen: fases+tareas con planned dates, needsValidation, source
  firmness         Json // resumen de firmeza: { taskCount, needsValidationCount, firmPct, label, ... }
  publishedByEmail String? // quién publicó (del guard)
  capturedAt       DateTime        @default(now())

  @@index([timelineId, isActive])
  @@index([timelineId, version])
}

// D.1 — los 5 tipos de actividad de una implementación (orden de negocio fijo).
// Mapean a colores/leyenda en el Gantt interno; el cliente no los ve.
enum TimelineActivityType {
  EXPLORACION
  PLANIFICACION
  CONFIGURACION
  ADOPCION
  SEGUIMIENTO
}

enum TimelineTaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  SUSPENDED // E — tarea aparcada/descartada: resuelta (no pendiente ni vencida), no se ejecutó
}

// ─── ProjectExternalAccess ────────────────────────────────────────────────────
// Mecanismo de acceso del cliente externo al landing de SU proyecto.
// Combinación token (URL) + contraseña hasheada (form). Necesita ambos.
// 1:1 con Project. El CSE genera/regenera/revoca desde el panel del proyecto.
// La contraseña se devuelve EN PLANO una sola vez al generarla; después solo
// queda el hash (bcrypt 12 rounds). Si se pierde, hay que regenerar.
// Coexiste con Project.shareToken (vista pública sin contraseña, feature aparte).

model ProjectExternalAccess {
  id             String      @id @default(cuid())
  projectId      String      @unique
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  accessToken    String      @unique // 64 chars hex (crypto.randomBytes(32))
  passwordHash   String // bcrypt(12 rounds) — lo usa verify-access
  accessPassword String? // texto plano (visible para el CSE en el panel; igual se entrega al cliente en claro). Null en accesos viejos pre-migración.
  enabledAt      DateTime    @default(now())
  revokedAt      DateTime? // si != null → acceso bloqueado
  lastUsedAt     DateTime? // se actualiza en cada verify OK
  createdById    String? // FK a TeamMember que generó el acceso (auditoría)
  createdBy      TeamMember? @relation("ExternalAccessCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([accessToken])
  @@index([projectId])
}

// Canvas dentro de un proyecto (default = "Canvas de servicio", custom = secciones libres)
model ProjectCanvas {
  id             String        @id @default(cuid())
  // Dueño flexible: el canvas cuelga de un Project (kickoff/diagnóstico/…) O de un
  // BusinessCase (Ventas). Exactamente uno seteado (validado en código).
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  businessCaseId String?
  businessCase   BusinessCase? @relation(fields: [businessCaseId], references: [id], onDelete: Cascade)
  name           String
  isDefault      Boolean       @default(false)
  order          Int           @default(0) // orden de aparición en el dropdown de canvases
  // Versionado (business case): cada "Generar" crea un canvas nuevo; isActive marca
  // el vivo/editable. En proyectos queda version=1/isActive=true (sin uso).
  version        Int           @default(1)
  isActive       Boolean       @default(true)
  sections       Json          @default("[]") // Array de { key, label, brief?, previousBrief? } — brief = guía del agente por sección (BC), acá y no en columna para sobrevivir db push entre las 2 PCs (ver lib/business-cases/section-briefs.ts)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // D.3 staging — el cliente ve el SNAPSHOT publicado; el contenido vivo es borrador hasta "Subir".
  // publishedSnapshot = foto client-safe al subir; contentUpdatedAt se toca al editar/confirmar bloques
  // (dispara "cambios sin subir" si contentUpdatedAt > publishedSnapshotAt).
  publishedSnapshot   Json?
  publishedSnapshotAt DateTime?
  contentUpdatedAt    DateTime?

  cards          ClientContextCard[]
  canvasSections CanvasSection[]

  @@index([projectId])
  @@index([businessCaseId])
}

// Sección de un canvas no-default (entidad de primer nivel)
model CanvasSection {
  id                      String        @id @default(cuid())
  canvasId                String
  canvas                  ProjectCanvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  key                     String
  label                   String
  titleOverride           String? // Título de cara al cliente editado por el CSE (landing Kickoff). null = título por defecto de la plantilla (SECTION_META).
  eyebrowOverride         String? // Eyebrow (título pequeño) editado por el CSE. null = eyebrow por defecto de la plantilla.
  // NOTA: la "guía del agente" por sección (business case) NO vive acá. Se guarda en
  // ProjectCanvas.sections (Json) para sobrevivir db push entre las 2 PCs que comparten
  // la DB de prod. Ver lib/business-cases/section-briefs.ts.
  // Deshacer de 1 nivel (persistido): valor inmediatamente anterior de title/eyebrow. null = nada que deshacer.
  previousTitleOverride   String?
  previousEyebrowOverride String?
  order                   Int           @default(0)
  layout                  Json? // RGL layout: [{ i: blockId, x, y, w, h }]
  createdAt               DateTime      @default(now())

  blocks CanvasBlock[]

  @@unique([canvasId, key])
  @@index([canvasId])
}

// Bloque de contenido dentro de una sección (text, heading, table, metric, callout, etc.)
model CanvasBlock {
  id              String        @id @default(cuid())
  sectionId       String
  section         CanvasSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  blockType       BlockType     @default(TEXT)
  content         String?       @db.Text
  data            Json?
  // Deshacer de 1 nivel (persistido): contenido/data inmediatamente anterior. null = nada que deshacer.
  previousContent String?       @db.Text
  previousData    Json?
  order           Int           @default(0)
  colSpan         Int           @default(4) // 1-4 columns width
  colStart        Int? // 1-4 column start position (null = auto)
  rowSpan         Int           @default(4) // height in grid rows
  source          BlockSource   @default(AGENT)
  status          BlockStatus   @default(DRAFT)
  agentRunId      String?
  agentRun        AgentRun?     @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())

  @@index([sectionId])
  @@index([agentRunId])
}

// Notas/contenido guardadas por etapa y paso dentro del workspace de un cliente
model StageNote {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage     Int // 1 = Diagnóstico | 2 = MVP | 3 = Adopción
  step      Int // número de paso dentro de la etapa (1-indexed)
  content   String   @default("") @db.Text

  updatedAt DateTime @updatedAt

  @@unique([clientId, stage, step])
}

// Documentos adjuntos al workspace de un cliente (transcripciones, briefs, URLs, etc.)
model ClientDocument {
  id        String       @id @default(cuid())
  clientId  String
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage     Int? // null = global (tab Documentos), 1 o 2 o 3 = etapa específica
  step      Int? // paso específico (opcional)
  title     String
  type      DocumentType
  content   String?      @db.Text // para FREE_TEXT / CALL_TRANSCRIPT pegado / texto extraído de FILE
  url       String? // para URL, Fireflies links, o Supabase Storage URL
  fileName  String? // nombre original del archivo (para FILE)
  fileSize  Int? // tamaño en bytes (para FILE)
  mimeType  String? // tipo MIME (para FILE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Cards de contexto del cliente (sección editable sobre la relación comercial, dolor, etc.)
model ClientContextCard {
  id         String     @id @default(cuid())
  clientId   String
  client     Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId  String?
  project    Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // null = card manual/legacy; set = generada por un AgentRun específico
  agentRunId String?
  agentRun   AgentRun?  @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  title      String
  content    String     @default("") @db.Text
  order      Int        @default(0)
  source     CardSource @default(HUMAN)
  cardType   CardType   @default(TEXT)

  // Canvas integration
  canvasId      String? // null = canvas default del proyecto
  canvas        ProjectCanvas? @relation(fields: [canvasId], references: [id], onDelete: SetNull)
  canvasSection String? // Sección del canvas donde vive (null = no está en canvas)
  canvasOrder   Int? // Orden dentro de la sección del canvas (para drag & drop)
  canvasStatus  String         @default("confirmed") // "draft" = auto-poblado por agente, pendiente de revisión; "confirmed" = aceptado por CSE

  // Card hierarchy (para clones al enviar al canvas)
  parentCardId String?
  parentCard   ClientContextCard?  @relation("CardClones", fields: [parentCardId], references: [id], onDelete: SetNull)
  clones       ClientContextCard[] @relation("CardClones")

  // Datos estructurados por tipo
  diagramData Json? // Para FLOWCHART: { nodes: [...], edges: [...] }
  chartConfig Json? // Para CHART: configuración de ECharts

  // Vista del cliente
  publishedToClient Boolean @default(false) // Si true, visible en la vista externa del cliente
  publishedContent  String? @db.Text // Versión alternativa del contenido para el cliente (lenguaje suavizado)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Cards de un mismo run no pueden tener el mismo título
  @@unique([agentRunId, title])
  @@index([clientId, agentRunId])
  @@index([agentRunId])
  @@index([canvasId])
  @@index([canvasSection])
  @@index([parentCardId])
}

// ─── HubspotAccount (ahora hijo de Client) ───────────────────────────────────

model HubspotAccount {
  id               String    @id @default(cuid())
  isSystem         Boolean   @default(false) // true = cuenta del sistema (Smarteam), false = cuenta de cliente
  clientId         String?   @unique // nullable en transición — se hará NOT NULL en Fase 5
  client           Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  hubspotPortalId  String    @unique
  hubName          String?
  accessToken      String
  refreshToken     String
  expiresAt        DateTime
  portalSnapshot   Json?
  portalSnapshotAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relaciones legacy (se eliminan en Fase 5 una vez migrada toda la data)
  implementations Implementation[]
  audits          Audit[]
  knowledge       Knowledge[]
}

// ─── Knowledge ────────────────────────────────────────────────────────────────

model Knowledge {
  id        String         @id @default(cuid())
  accountId String
  account   HubspotAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  clientId  String? // se poblará en migración de datos (Fase 5)
  client    Client?        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title     String
  content   String         @db.Text
  category  String         @default("general")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// ─── Audit ────────────────────────────────────────────────────────────────────

model Audit {
  id        String          @id @default(cuid())
  accountId String? // nullable en transición (Fase 3 lo migra a clientId)
  account   HubspotAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  clientId  String? // nuevo FK a Client (se poblará en Fase 3)
  client    Client?         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  data      Json?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

// ─── Implementation ───────────────────────────────────────────────────────────

model Implementation {
  id        String               @id @default(cuid())
  accountId String? // nullable en transición (Fase 4 lo migra a clientId)
  account   HubspotAccount?      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  clientId  String? // nuevo FK a Client (se poblará en Fase 4)
  client    Client?              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  status    ImplementationStatus @default(PLANNING)
  archived  Boolean              @default(false)
  plan      Json?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  messages   Message[]
  executions ExecutionLog[]
}

// ─── Message ──────────────────────────────────────────────────────────────────

model Message {
  id               String         @id @default(cuid())
  implementationId String
  implementation   Implementation @relation(fields: [implementationId], references: [id], onDelete: Cascade)
  role             String
  content          String         @db.Text
  createdAt        DateTime       @default(now())
}

// ─── Agent ────────────────────────────────────────────────────────────────────

model Agent {
  id                     String          @id @default(cuid())
  name                   String
  description            String?
  systemPrompt           String          @db.Text
  additionalInstructions String?         @db.Text
  status                 AgentStatus     @default(DRAFT)
  // Etapas asociadas: [] = aplica a todas, [1] = solo Etapa 1, [1,2] = ambas
  associatedStages       Int[]
  associatedStep         Int?
  sectionLabel           String? // Bloque visual dentro de la subetapa (ej. "Contexto del cliente")
  outputType             AgentOutputType @default(CARDS)
  scope                  AgentScope      @default(CLIENT)
  agentType              AgentType       @default(SECTION)
  defaultCanvasSection   String? // Sección del canvas de proyecto sugerida al enviar cards (ej. "procesos")
  // Agrupación por propósito (reemplaza stages/steps para la UI)
  agentGroup             String? // handoff | preparacion | diagnostico | planificacion | ejecucion | adopcion (ver lib/agent-groups.ts)
  groupOrder             Int             @default(0) // Orden DENTRO de su grupo (no del grupo). Para chaining: agentes con groupOrder menor se inyectan como contexto a los mayores del mismo grupo.
  // IDs de KnowledgeDocument inyectados sin truncar al prompt del agente (referencia principal)
  pinnedKnowledgeIds     String[]        @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs AgentRun[]

  @@index([associatedStep])
}

model AgentRun {
  id             String         @id @default(cuid())
  agentId        String?
  agent          Agent?         @relation(fields: [agentId], references: [id], onDelete: SetNull)
  // nullable porque los reportes de cartera agregada (Cobranza fase 3) no
  // pertenecen a UN cliente — todos los demás writers siguen seteándolo.
  clientId       String?
  client         Client?        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  businessCaseId String?
  businessCase   BusinessCase?  @relation(fields: [businessCaseId], references: [id], onDelete: Cascade)
  stage          Int?
  step           Int?
  stepLabel      String? // nombre legible de la subetapa (ej. "Análisis inicial")
  sectionLabel   String? // sección dentro de la subetapa (ej. "Contexto del cliente")
  serviceType    String? // tipo de servicio al momento de la ejecución
  status         AgentRunStatus @default(PENDING)
  // Fase actual legible para el polling de UI en operaciones largas
  // ("Leyendo contexto…", "Generando secciones…"). Aditivo, opcional — los
  // flujos que no la escriben siguen igual (F5.2 del plan de mejoras).
  currentPhase   String?
  output         String?        @db.Text // JSON raw de Claude (backup)

  // ── Análisis contextuales desde /sessions (Fase 9) ──────────────────────────
  sourceSessionIds String[] @default([]) // ids de FirefliesSession usados como input
  filters          Json? // snapshot de filtros: { from, to, teamRoles[], onlyWithContent }
  agentSlug        String? // identificador estable: "sales-analysis" | "service-analysis"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cards                    ClientContextCard[]
  blocks                   CanvasBlock[]
  generatedTimelines       ProjectTimeline[]
  detailGeneratedTimelines ProjectTimeline[]   @relation("TimelineDetailGenerator")
  csAlerts                 CsAlert[] // Éxito del cliente: alertas emitidas por esta corrida

  @@index([status])
  @@index([clientId, agentSlug, createdAt])
}

// ─── Business Cases (Ventas) — generador de casos de negocio ─────────────────
// Entidad 1:N bajo Client (NO bajo Project). Flujo: generar (agente) →
// editar/confirmar (vendedor) → publicar (snapshot congelado + acceso
// token+password, mismo patrón que ProjectExternalAccess).

model BusinessCase {
  id               String             @id @default(cuid())
  clientId         String
  client           Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  hubspotCompanyId String? // empresa de HubSpot asociada al caso
  hubspotDealId    String? // deal de HubSpot (opcional)
  name             String
  slug             String             @unique // referencia interna (URLs de admin)
  status           BusinessCaseStatus @default(DRAFT)

  // Idioma del caso (código ISO 639-1, ej. "es"/"en") — fuente de verdad persistente
  // para que TODAS las secciones generen/editen en el mismo idioma. Antes vivía solo
  // como key no-schema `__lang` en el data del bloque hero (frágil); ahora se persiste
  // acá y el hero queda como fallback para casos viejos pre-migración.
  // SIN @default: si tuviera default, Postgres lo aplicaría (virtualmente) a las filas
  // YA EXISTENTES sin rewrite de tabla — casos viejos en inglés leerían "es" acá y
  // el fallback al __lang del hero (que sí tiene el idioma correcto) nunca se activaría.
  language String?

  // Clasificación (tira de tags) — MISMO catálogo y modalidad que Project (lib/tags/catalog.ts).
  // El agente del BC los detecta; el CSE corrige. Se PROPAGAN al Project al crear el handoff
  // (match por hubspotDealId). tags = slugs de product+scope; implementationType = modalidad.
  tags               String[]            @default([])
  implementationType ImplementationType?

  // Tipo de caso (slug del catálogo TS en lib/business-cases/case-types.ts) — determina
  // template de landing + tags seed. String? y NO enum (agregar tipos sin migración;
  // valor desconocido degrada al default). null = implementación HubSpot (legacy/default).
  // Respaldo dual-PC: la entry `__meta` del Json sections del canvas v0 (template-meta.ts).
  caseType    String?
  caseSubtype String? // sub-tipo (website: "ecommerce" | "informativo")

  // D.3 staging — el prospecto ve el SNAPSHOT publicado; el contenido vivo es
  // borrador hasta "Publicar". publishedSnapshot = foto client-safe de bloques.
  publishedAt       DateTime?
  publishedSnapshot Json?

  createdByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  blocks      BusinessCaseBlock[] // (v1 — se elimina en la limpieza F7)
  canvases    ProjectCanvas[] // canvases versionados (cada "Generar" = uno nuevo)
  sessions    BusinessCaseSession[] // sesiones de contexto incluidas/excluidas
  transcripts BusinessCaseTranscript[]
  useCases    BusinessCaseUseCase[] // checklist del catálogo de casos de uso
  access      BusinessCaseExternalAccess?
  agentRuns   AgentRun[]

  @@index([clientId])
}

// ─── Catálogo de casos de uso (Ventas) ────────────────────────────────────────
// Checklist INTERNO del vendedor: casos de uso pre-armados con precio que se marcan
// por BC y se materializan determinísticamente en la sección `casos_de_uso` (el
// agente NUNCA los genera → precios exactos). 100% opcional: sin filas aplicables,
// el flujo de texto libre sigue idéntico. Tabla propia (NO KnowledgeDocument: los
// docs PUBLISHED se inyectan al contexto de OTROS agentes y esto lleva precios).
model UseCase {
  id             String   @id @default(cuid())
  title          String
  description    String   @db.Text // markdown corto (checklist + landing)
  price          String? // TEXTO libre mostrable ("USD 1.200", "desde $X/mes") — NUNCA numérico (sin calculadora, por diseño)
  appliesTo      String[] @default([]) // slugs de caseType (case-types.ts); [] = aplica a TODOS los tipos
  tags           String[] @default([]) // slugs del catálogo lib/tags (mismo vocabulario que BusinessCase.tags)
  active         Boolean  @default(true)
  order          Int      @default(0)
  createdByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  businessCases BusinessCaseUseCase[]

  @@index([active])
}

// Pivote BC ↔ caso de uso — espejo de BusinessCaseSession. SEMÁNTICA: sin fila = no
// seleccionado; la fila se crea recién al primer toggle (un seed que cree filas para
// todos los candidatos invertiría el default). La verdad PUBLICABLE es el `data` de
// la sección `casos_de_uso` del canvas; el pivote es estado de trabajo + input del prompt.
model BusinessCaseUseCase {
  id             String       @id @default(cuid())
  businessCaseId String
  businessCase   BusinessCase @relation(fields: [businessCaseId], references: [id], onDelete: Cascade)
  useCaseId      String
  useCase        UseCase      @relation(fields: [useCaseId], references: [id], onDelete: Cascade)
  selected       Boolean      @default(true)
  priceOverride  String? // precio negociado para ESTE caso (texto)
  createdAt      DateTime     @default(now())

  @@unique([businessCaseId, useCaseId])
  @@index([businessCaseId])
}

model BusinessCaseSession {
  id             String       @id @default(cuid())
  businessCaseId String
  businessCase   BusinessCase @relation(fields: [businessCaseId], references: [id], onDelete: Cascade)
  sessionId      String // FirefliesSession.id (sin FK dura: la sesión puede no existir aún)
  included       Boolean      @default(true) // el vendedor incluye/excluye del contexto de generación
  createdAt      DateTime     @default(now())

  @@unique([businessCaseId, sessionId])
  @@index([businessCaseId])
}

model BusinessCaseBlock {
  id               String                @id @default(cuid())
  businessCaseId   String
  businessCase     BusinessCase          @relation(fields: [businessCaseId], references: [id], onDelete: Cascade)
  blockType        BusinessCaseBlockType
  order            Int                   @default(0)
  content          Json // estructurado por blockType (ver lib/business-cases/schema.ts)
  previousContent  Json? // deshacer de 1 nivel
  status           BlockStatus           @default(DRAFT)
  source           BlockSource           @default(AGENT)
  isVisible        Boolean               @default(true)
  needsValidation  Boolean               @default(false) // el agente no tuvo contexto suficiente
  confirmedAt      DateTime?
  confirmedByEmail String?
  agentRunId       String? // provenance (sin FK dura)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([businessCaseId])
}

model BusinessCaseTranscript {
  id             String                       @id @default(cuid())
  businessCaseId String
  businessCase   BusinessCase                 @relation(fields: [businessCaseId], references: [id], onDelete: Cascade)
  source         BusinessCaseTranscriptSource
  rawText        String                       @db.Text // pegado, o texto extraído del archivo
  fileName       String?
  fileUrl        String? // path en Supabase Storage (UPLOADED)
  fileSize       Int?
  mimeType       String?
  processedAt    DateTime?
  createdAt      DateTime                     @default(now())

  @@index([businessCaseId])
}

model BusinessCaseExternalAccess {
  id             String       @id @default(cuid())
  businessCaseId String       @unique
  businessCase   BusinessCase @relation(fields: [businessCaseId], references: [id], onDelete: Cascade)
  accessToken    String       @unique // 64 hex (crypto.randomBytes(32))
  passwordHash   String // bcrypt(12)
  accessPassword String? // texto plano para que el vendedor lo comparta
  enabledAt      DateTime     @default(now())
  revokedAt      DateTime?
  lastUsedAt     DateTime?
  createdByEmail String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([accessToken])
  @@index([businessCaseId])
}

// Token de un solo uso, de vida ultra-corta, para que Puppeteer (server-to-server,
// mismo contenedor) autentique su navegación a /print/business-case/[id] SIN
// reenviar las cookies reales de sesión Supabase (que pueden venir partidas en
// varias cookies `sb-*`) — mismo principio que BusinessCaseExternalAccess, pero
// de un solo uso y con TTL de segundos en vez de una sesión de acceso duradera.
// Rate-limit PERSISTIDO del verify-access externo (proyecto y business case).
// Antes era un Map en memoria: cada deploy lo reseteaba y un atacante podía
// re-intentar tras cada restart. Una fila por token atacado; el job
// maintenance-daily barre filas viejas.
model ExternalVerifyAttempt {
  token         String    @id // el accessToken al que se intenta entrar (64 hex)
  count         Int       @default(0)
  windowStartAt DateTime
  blockedUntil  DateTime?
  updatedAt     DateTime  @updatedAt
}

model PrintJobToken {
  id             String    @id @default(cuid())
  token          String    @unique // 64 hex (crypto.randomBytes(32))
  businessCaseId String
  canvasId       String? // null = canvas activo al momento de generar
  createdByEmail String?
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([token])
  @@index([expiresAt])
}

// ─── TeamMember ───────────────────────────────────────────────────────────────
// Identidad interna del equipo de Smarteam. El email es la llave que cruza
// con AppUser.email (que a su vez se vincula con auth.users de Supabase Auth).
// El roleEnum reemplaza al string legacyRole; el viejo se mantiene para
// auditoría de migración y se elimina cuando estabilice el roleEnum.

model TeamMember {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  // ÁREA FUNCIONAL — eje de ANÁLISIS de sesiones, NO permisos. Valores: Ventas,
  // CSE, CSL, Marketing, Development, PM, Admin, RevOps (set abierto). Antes se
  // llamaba `role`; se renombró a `area` para no confundir con roleEnum (permisos).
  // Marco Salas, p.ej., es roleEnum=SUPER_ADMIN pero area=Ventas (análisis).
  area                String?
  // ROL DE PERMISO — única fuente de verdad de acceso/capacidades. Ver lib/auth/roles.ts.
  roleEnum            TeamRole  @default(CSE)
  // Foto de la persona (bucket público, subida desde /team). Se muestra en el
  // selector de equipo del Kickoff (snapshoteada al seleccionar). nullable = sin foto → iniciales.
  photoUrl            String?
  // Visibilidad total HOY se deriva del rol (todos menos CSE ven todo). Este flag
  // queda como override excepcional (ej. un CSE con acceso temporal a todo).
  canViewAllClients   Boolean   @default(false)
  canViewAllExpiresAt DateTime?
  // Overrides de PERMISOS por usuario (matriz sección×acción, lib/auth/permissions):
  // Json SPARSE {v:1, sections:{[seccion]:{[accion]:bool}}} — solo las celdas que el
  // SUPER_ADMIN pineó para ESTE usuario; ausencia = hereda la plantilla del rol
  // (RolePermission) o el default de código. null = hereda todo. Lectura tolerante.
  permissionOverrides Json?
  // Baja blanda: si != null, el miembro pierde acceso (login bloqueado) y desaparece
  // de los listados de personas, pero su histórico (sesiones/handoffs/runs) queda intacto.
  deactivatedAt       DateTime?
  deactivatedReason   String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Inversas
  appUser                 AppUser?
  clientAssignments       ClientAssignment[]      @relation("AssignedTo")
  grantedAssignments      ClientAssignment[]      @relation("GrantedBy")
  externalAccessesCreated ProjectExternalAccess[] @relation("ExternalAccessCreator")
  // SUPER_ADMIN-only (salarios estimados, Cobranza fase 4) — JAMÁS incluir esta
  // relación desde endpoints no-costos; Prisma no la trae sin include explícito.
  costosRecurrentes       CostoRecurrente[]       @relation("CostosDePersona")
}

enum TeamRole {
  CSE // scoped: solo sus clientes asignados (owner) + los compartidos
  VENTAS // ve todo + handoff en cualquiera; NO comparte
  CSL // ve todo + handoff en cualquiera + comparte; NO gestiona equipo
  MARKETING // capacidades = CSL (etiqueta distinta para análisis/UI)
  DEV // equipo técnico: capacidades = VENTAS (ve todo + cronogramas + handoffs) + área Ventas
  ADMIN // asistente administrativo (Finanzas): SOLO Cobranza (via COBRANZA_ROLES) — 0 capacidades de la matriz
  SUPER_ADMIN // todo + ÚNICO que gestiona el equipo (alta/baja/cambio de rol)
}

// ─── RolePermission ───────────────────────────────────────────────────────────
// PLANTILLA de permisos por rol, editable vía UI (/team, solo SUPER_ADMIN).
// `permissions` = PermissionMap COMPLETO {v:1, sections:{[seccion]:{[accion]:bool}}}
// validado contra el registry (lib/auth/permissions). Precedencia efectiva:
// DEFAULT_MATRIX (código) ← esta fila (DB, cache TTL 60s) ← TeamMember.permissionOverrides.
// Fila ausente o Json inválido → default de código (deploy-safe con tabla vacía).
// SUPER_ADMIN nunca se lee de acá: all-true hardcodeado en el engine (anti-lockout).

model RolePermission {
  role           TeamRole @id
  permissions    Json
  updatedAt      DateTime @updatedAt
  updatedByEmail String?
}

// ─── AppUser ──────────────────────────────────────────────────────────────────
// Identidad unificada que vincula auth.users (Supabase Auth) con el modelo
// de Nexus. Hay dos kinds:
//   - INTERNAL: equipo de Smarteam. teamMemberId set, clientId null.
//   - EXTERNAL: cliente final (onboarding). clientId set, teamMemberId null.
// El authUserId se vincula en el primer login (callback de Google OAuth).

model AppUser {
  id           String      @id @default(cuid())
  authUserId   String?     @unique // FK suave a auth.users.id de Supabase (null hasta primer login)
  email        String      @unique
  kind         AppUserKind
  teamMemberId String?     @unique
  teamMember   TeamMember? @relation(fields: [teamMemberId], references: [id], onDelete: SetNull)
  clientId     String?
  client       Client?     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([email])
  @@index([authUserId])
}

enum AppUserKind {
  INTERNAL
  EXTERNAL
}

// ─── ClientAssignment ─────────────────────────────────────────────────────────
// Overrides manuales bidireccionales para la asignación CSE↔Cliente, en
// adición al default automático (hubspotOwnerEmail). GRANT da acceso a un
// CSE a un cliente que no es su owner; REVOKE quita acceso a un CSE que sí
// es owner (raro). Solo ADMIN/SUPER_ADMIN puede crearlos (grantedById).

model ClientAssignment {
  id           String         @id @default(cuid())
  clientId     String
  client       Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Target del compartir: a UNA persona (teamMemberId) O a un ROL entero
  // (targetRole, ej. CSE = "todo el equipo CSE"). Exactamente uno de los dos.
  teamMemberId String?
  teamMember   TeamMember?    @relation("AssignedTo", fields: [teamMemberId], references: [id], onDelete: Cascade)
  targetRole   TeamRole?
  kind         AssignmentKind
  grantedById  String // FK al TeamMember (CSL/SUPER_ADMIN) que compartió
  grantedBy    TeamMember     @relation("GrantedBy", fields: [grantedById], references: [id], onDelete: Restrict)
  reason       String?        @db.Text
  createdAt    DateTime       @default(now())

  // NULLs son distintos en PG → la unicidad real la garantizan los scripts esta
  // vuelta (no hay UI). Se reforzará con constraint parcial cuando llegue la UI.
  @@unique([clientId, teamMemberId, targetRole])
  @@index([teamMemberId])
  @@index([clientId])
}

enum AssignmentKind {
  GRANT
  REVOKE
}

// ─── ExecutionLog ─────────────────────────────────────────────────────────────

model ExecutionLog {
  id               String          @id @default(cuid())
  implementationId String
  implementation   Implementation  @relation(fields: [implementationId], references: [id], onDelete: Cascade)
  action           String
  resource         String
  status           ExecutionStatus
  details          Json
  createdAt        DateTime        @default(now())
}

// ============================================
// KNOWLEDGE BASE — Documentos de conocimiento
// ============================================

enum KnowledgeType {
  PROCESS // Procesos operativos (cómo ejecutar una fase, cadencia semanal, etc.)
  METHODOLOGY // Metodologías (Inbound, Loop Framework, gestión del cambio)
  HUBSPOT_SPEC // Features y specs de HubSpot (releases, capacidades, limitaciones)
  BEST_PRACTICE // Mejores prácticas descubiertas en proyectos anteriores
  TEMPLATE // Plantillas reutilizables (agendas, estructuras de informes, etc.)
}

enum KnowledgeStatus {
  DRAFT // En borrador, no visible para agentes
  PUBLISHED // Activo, los agentes lo consultan
  ARCHIVED // Obsoleto, no se consulta pero se conserva
}

enum TagCategory {
  SERVICE // Servicio: loop_marketing, loop_sales, loop_service, proyecto_temporal
  STAGE // Etapa: diagnostico, mvp, adopcion
  SUBSTAGE // Subetapa: analisis_inicial, funnel, mapeo, kickoff, piloto, escalamiento, etc.
  DOMAIN // Dominio funcional: marketing, sales, service, cross_department
  HUBSPOT_AREA // Área de HubSpot: crm, automation, reporting, breeze, workflows, pipelines
  TOPIC // Tema libre: gestion_cambio, liderazgo, onboarding, data_quality, etc.
}

model KnowledgeDocument {
  id     String          @id @default(cuid())
  type   KnowledgeType
  status KnowledgeStatus @default(DRAFT)

  title   String
  summary String? // Resumen corto para listados y contexto rápido de agentes
  content String  @db.Text // Contenido completo en Markdown

  version Int @default(1)

  // Autoría (sin modelo User — usamos email de sesión)
  createdByEmail String?
  updatedByEmail String?

  tags       KnowledgeTag[]
  embeddings KnowledgeEmbedding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
  @@index([createdAt])
}

// ============================================
// SISTEMA DE TAGS — Taxonomía para filtrado
// ============================================

model KnowledgeTag {
  id       String      @id @default(cuid())
  category TagCategory
  value    String // Ej: "loop_marketing"
  label    String // Ej: "Loop Marketing"

  documents KnowledgeDocument[]

  @@unique([category, value])
  @@index([category])
}

// ============================================
// EMBEDDINGS — Para búsqueda semántica futura
// ============================================

model KnowledgeEmbedding {
  id         String            @id @default(cuid())
  documentId String
  document   KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  chunkIndex Int    @default(0)
  chunkText  String @db.Text

  // El vector se agrega vía SQL directo en Supabase (pgvector, 1024 dims)
  // ALTER TABLE "KnowledgeEmbedding" ADD COLUMN embedding vector(1024);

  createdAt DateTime @default(now())

  @@index([documentId])
}

// ── FirefliesSession — caché local de sesiones de Fireflies y Google Meet ─────

model FirefliesSession {
  id               String    @id
  title            String
  date             DateTime
  duration         Float     @default(0)
  participants     String[]
  summary          Json?
  transcript       String?   @db.Text
  enrichedAt       DateTime? // cuándo se trajo transcript/summary (null = pendiente)
  syncedAt         DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  source           String    @default("google_meet") // "google_meet" (Fireflies eliminado; "fireflies" solo en filas históricas)
  googleDocId      String? // ID del Google Doc de la reunión (Meet)
  googleEventId    String? // ID del evento de Google Calendar (Meet)
  organizerEmail   String? // Email del organizador (para impersonación en enriquecimiento)
  manualClientId   String? // override manual del matching automático de cliente
  resolvedClientId String? // PERF #1: cliente resuelto (materializado de categorizeSession) para "última actividad"/bookends sin cargar todas las sesiones. Re-resuelto en write/override/mutación de Client.

  // F5: sub-topics detectados por IA (lead-scoring, workflow-builder, etc.).
  // Lista canónica viva en lib/sessions/topic-vocabulary.ts y se sesga por
  // serviceType del proyecto primario.
  detectedTopics String[] @default([])

  // Relaciones del ciclo de reunión (minuta post + acciones derivadas)
  minute      SessionMinute?
  actionItems ActionItem[]
  projects    SessionProject[]

  // Índices para los queries principales:
  //   /sessions: findMany({ where: { date: { lt: now } }, orderBy: { date: desc } })
  //   override manual: filtros por manualClientId al matchear sesiones
  // Sin esto, Postgres hace seq scan + sort en cada render.
  @@index([date(sort: Desc)])
  @@index([manualClientId])
  @@index([resolvedClientId, date(sort: Desc)])
}

// ─── Ciclo de reunión: Minuta + ActionItems ──────────────────────────────────
// Estos modelos encarnan el flujo del CSE:
//   1. La reunión sucede (FirefliesSession con transcript)
//   2. El agente Post-sesión genera SessionMinute (DRAFT) + ActionItems
//   3. El CSE revisa la minuta (DRAFT → REVIEWED) y trabaja las acciones
//   4. La siguiente sesión vuelve a iterar

enum MinuteStatus {
  DRAFT // generada por agente, esperando revisión del CSE
  REVIEWED // CSE la revisó y aceptó sin cambios
  EDITED // CSE la editó manualmente (también implica aceptada)
}

enum ActionStatus {
  PENDING
  IN_PROGRESS
  BLOCKED
  DONE
}

model SessionMinute {
  id        String           @id @default(cuid())
  sessionId String           @unique
  session   FirefliesSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Síntesis estructurada de la reunión
  summary    String @db.Text // resumen ejecutivo (1-2 párrafos)
  agreements Json? // [{ text, source? }]
  decisions  Json? // [{ text, rationale? }]
  risks      Json? // [{ text, severity? "low" | "med" | "high" }]
  topics     Json? // ["bullet 1", "bullet 2"]

  // Estado y trazabilidad
  status                MinuteStatus @default(DRAFT)
  generatedByAgentRunId String? // FK suave (no cascade) al AgentRun que la creó
  reviewedAt            DateTime?
  reviewedByEmail       String? // email del CSE que aceptó/editó

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model ActionItem {
  id   String @id @default(cuid())
  text String @db.Text

  clientId  String
  client    Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sessionId String?
  session   FirefliesSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  // Asignación y plazos
  ownerEmail String?
  dueDate    DateTime?
  status     ActionStatus @default(PENDING)
  done       Boolean      @default(false)

  // Trazabilidad de origen
  source                String? // "agent:post-session" | "agent:sales-analysis" | "manual" | "legacy" | "agent:client-analyze"
  generatedByAgentRunId String? // FK suave al AgentRun que lo creó

  // Soft-delete: borrar una tarea NO la elimina; setea deletedAt para que siga
  // visible en el "Histórico" del modal de pendientes (tareas hechas o borradas).
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, done])
  @@index([projectId, done])
  @@index([projectId, deletedAt])
  @@index([sessionId])
  @@index([ownerEmail, done])
  @@index([dueDate])
}

// ─── SessionProject — pivote N:N entre FirefliesSession y Project ─────────────
// Una sesión puede tocar múltiples proyectos del mismo cliente (ej. una reunión
// de "alineación general" que cubre marketing + ventas). isPrimary indica el
// proyecto principal donde se ve la minuta/cards/acciones por defecto.
// source: "agent" (clasificador automático) | "manual" (CSE) | "legacy" (migración).

model SessionProject {
  id        String           @id @default(cuid())
  sessionId String
  session   FirefliesSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  projectId String
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  isPrimary       Boolean  @default(false)
  source          String   @default("agent") // "agent" | "manual" | "legacy"
  confidence      Float? // 0..1, solo si source="agent"
  rationale       String?  @db.Text // por qué la IA lo asignó
  // Override del humano para el HANDOFF, independiente del filtro automático (título de
  // venta/handoff/kickoff o Ventas en la sala): null = seguí la regla; true = forzá
  // incluir (agregada a mano desde el pop-up); false = forzá excluir (la "X" del panel).
  handoffOverride Boolean?

  generatedByAgentRunId String? // FK suave al AgentRun del clasificador
  createdAt             DateTime @default(now())

  // ── Membresía de contexto (plan "contexto por proyecto", 2026-07-10) ──
  // included: LA verdad de "¿esta sesión alimenta este proyecto?" que respetan
  // TODOS los consumidores (handoff/cronograma/entregas/minutas vía chokepoints).
  // false = excluida por un humano — TOMBSTONE durable: la fila queda como memoria
  // para que el clasificador IA no re-proponga el link (un DELETE sí se re-crearía).
  // handoffOverride sigue siendo el único afinado POR CONSUMIDOR (solo handoff):
  // "¿es de este proyecto?" ≠ "¿cuenta la historia de venta?".
  included   Boolean   @default(true)
  // Confirmación humana del link (IA propone, CSE confirma). Un link con reviewedAt
  // NUNCA es modificado/borrado por el clasificador (lock por link, no por sesión).
  reviewedAt DateTime?
  reviewedBy String? // email de quien curó

  @@unique([sessionId, projectId])
  @@index([projectId, isPrimary])
  @@index([sessionId])
}

// ─── Snapshot del análisis de participantes por proyecto (F5) ─────────────────
// Generado periódicamente por agent-participants-analyzer. Sobreescribible.

model ProjectParticipantSnapshot {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  stats                 Json // { clientSponsorAttendance, lastSeenByRole, averageHeadcount, ... }
  sessionsAnalyzed      Int     @default(0)
  generatedByAgentRunId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Canvas Suggestions (aprobación de cambios al Client Canvas) ─────────────

model CanvasSuggestion {
  id             String   @id @default(cuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agentRunId     String?
  section        String // key del canvas: "perfil", "stakeholders", etc.
  field          String? // campo específico dentro de la sección (para sugerencias granulares)
  current        Json? // valor actual de la sección al momento de la sugerencia
  suggested      Json // valor sugerido por el agente
  suggestedValue String?  @db.Text // valor sugerido como texto (alternativa a JSON)
  status         String   @default("pending") // pending | accepted | rejected
  source         String? // de dónde viene: "run:ID", "fireflies:TITLE", "manual"
  sourceLabel    String? // label legible: "Análisis inicial · 24 mar", "Sesión kickoff UCI"
  createdAt      DateTime @default(now())

  @@index([clientId, status])
}

// ─── SessionCategory — agrupación administrable de sesiones por dominio ──────
// Sirve para categorizar sesiones de Google Meet / Fireflies por el dominio
// de sus participantes (ej: "Interna" = @smarteamcr.com, "Partner HubSpot" = @hubspot.com).
// Los matching de Client.emailDomains tienen prioridad — esto categoriza el RESTO.

model SessionCategory {
  id        String   @id @default(cuid())
  name      String   @unique // "Interna", "Partner HubSpot", "Partner AtomChat"
  slug      String   @unique // "interna", "partner-hubspot" (URL-safe)
  domains   String[] // ["smarteamcr.com"], ["hubspot.com", "hubspotcr.com"]
  kind      String   @default("custom") // "internal" | "partner" | "custom" — semántica para UI/orden
  color     String? // hex (#94A3B8) para tag visual en sidebar
  order     Int      @default(0) // orden de aparición en sidebar
  isDefault Boolean  @default(false) // las default no se pueden eliminar (sí editar)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════════════════
// MARKETING + CONTENIDO — módulo single-tenant (equipo Smarteam; NADA cuelga de
// Client). Insumos curados (ICP, personas, pilares, fuentes, voz) + posts de
// inspiración scrapeados de LinkedIn + salidas del agente (ideas/campañas/
// sugerencias de pilar) + corridas (ingesta/generación) + lock del cron semanal.
// ═══════════════════════════════════════════════════════════════════════════════

enum IcpSection {
  FIRMOGRAFICA_DESCRIPTOR // Firmográfica — descriptores
  FIRMOGRAFICA_INDUSTRIA // Firmográfica — industrias con validación real
  BEHAVIORAL_REVENUE // Behavioral — revenue intelligence
  BEHAVIORAL_CANALES // Behavioral — canales y comportamiento
  BEHAVIORAL_ORG // Behavioral — la organización
  BEHAVIORAL_DECISION // Behavioral — estructura de decisión
  SIGNAL_ANTI // Señales — Anti-ICP
  SIGNAL_FUERTE // Señales fuertes
  SIGNAL_MEDIA // Señales medias
  SIGNAL_DEBIL // Señales débiles
}

enum PillarOrigin {
  HUMAN // creado a mano por el equipo
  AGENT // nació de una PillarSuggestion aprobada
}

enum MarketingApprovalStatus {
  PENDING
  APPROVED
  DISCARDED
}

enum CampaignChannel {
  GOOGLE_SEARCH
  PAID_SOCIAL
  DISPLAY
  OTHER
}

enum MarketingRunKind {
  INGEST // solo scraping de fuentes
  GENERATE // solo agente de generación (sobre lo guardado)
  CHAIN // ingesta → generación (si hubo posts nuevos)
}

enum MarketingRunTrigger {
  MANUAL // CTA en /contenido
  CRON // viernes 6:00 America Costa Rica
}

enum MarketingRunStatus {
  RUNNING
  DONE
  ERROR
}

// Config singleton del módulo (id="marketing"): voz de marca + lock del cron.
model MarketingSettings {
  id              String    @id @default("marketing")
  brandVoice      String    @db.Text // voz/posicionamiento (markdown) — editable en /marketing/voz
  lastCronRunAt   DateTime? // nullable porque nunca corrió — display en /contenido
  lastCronDateKey String? // nullable ídem — "YYYY-MM-DD" (día CR) del último disparo; claim atómico anti-doble-fire
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Ítem del ICP (migrado del hardcode de app/icp/ICPSection.tsx). 1 fila = 1 bullet.
model IcpItem {
  id        String     @id @default(cuid())
  section   IcpSection
  label     String     @db.Text
  order     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([section, order])
}

// Buyer persona — insumo curado que alimenta al agente de generación.
model BuyerPersona {
  id          String   @id @default(cuid())
  name        String
  role        String? // nullable porque el cargo/segmento puede cargarse después
  description String   @db.Text // quién es, contexto (markdown)
  pains       String?  @db.Text // nullable porque se carga incremental
  goals       String?  @db.Text // nullable ídem
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
}

// Pilar de contenido (tema/enfoque). Los AGENT nacen al aprobar una PillarSuggestion.
model ContentPillar {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?      @db.Text // nullable porque un pilar puede ser solo un nombre al alta
  origin      PillarOrigin @default(HUMAN)
  active      Boolean      @default(true)
  isCampaign  Boolean      @default(false) // énfasis de campaña: sesga la generación hacia este tema (activa = isCampaign && active)
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  ideas      ContentIdea[]
  suggestion PillarSuggestion?
}

// Fuente de inspiración: perfil público de LinkedIn (se scrapea vía InspirationProvider).
model InspirationSource {
  id             String    @id @default(cuid())
  profileUrl     String    @unique
  label          String? // nullable porque al alta a veces solo hay URL
  active         Boolean   @default(true)
  lastFetchedAt  DateTime? // nullable hasta la primera ingesta
  lastFetchError String?   @db.Text // nullable = última ingesta OK; error del provider si falló
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  posts InspirationPost[]

  @@index([active])
}

// Post scrapeado de una fuente. Dedup por externalId. "Archivado" NO es campo:
// la generación filtra postedAt >= hoy-3 meses; lo viejo queda fuera del contexto.
model InspirationPost {
  id           String            @id @default(cuid())
  sourceId     String
  source       InspirationSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  externalId   String            @unique // id/URN del post en LinkedIn — DEDUP KEY
  url          String? // nullable porque algunos actors no devuelven permalink
  authorName   String? // nullable ídem
  text         String            @db.Text
  likeCount    Int               @default(0)
  commentCount Int               @default(0)
  repostCount  Int               @default(0)
  hasImage     Boolean           @default(false)
  postedAt     DateTime
  fetchedAt    DateTime          @default(now())

  ideaSources ContentIdeaSource[]

  @@index([postedAt])
  @@index([sourceId, postedAt])
}

// Corrida del módulo (ingesta/generación/cadena). Modelo PROPIO: AgentRun exige
// clientId (NOT NULL) y esto es single-tenant. Trazabilidad estilo regla 6.5.
model MarketingRun {
  id                     String              @id @default(cuid())
  kind                   MarketingRunKind
  trigger                MarketingRunTrigger @default(MANUAL)
  status                 MarketingRunStatus  @default(RUNNING)
  phase                  String? // nullable cuando terminó — copy de progreso ("ingesta 3/8")
  newPostsCount          Int? // nullable hasta terminar la ingesta — posts NUEVOS post-dedup
  fetchedPostsCount      Int? // total traído del provider
  sourcesOkCount         Int?
  sourcesErrorCount      Int?
  contentIdeasCount      Int? // nullable hasta terminar la generación
  campaignIdeasCount     Int?
  pillarSuggestionsCount Int?
  error                  String?             @db.Text // mensaje REAL cuando status=ERROR
  rawOutput              String?             @db.Text // JSON crudo de Claude (backup/debug)
  startedByEmail         String? // nullable porque el CRON no tiene usuario
  createdAt              DateTime            @default(now())
  finishedAt             DateTime?

  contentIdeas      ContentIdea[]
  campaignIdeas     CampaignIdea[]
  pillarSuggestions PillarSuggestion[]

  @@index([status, createdAt])
  @@index([kind, createdAt])
}

// Idea de contenido generada — salida NO-CRUD: se revisa y se PODA (DELETE).
// Registro estructurado por campo para migrar a HubSpot copiando campo a campo.
model ContentIdea {
  id                  String         @id @default(cuid())
  runId               String? // nullable porque la idea sobrevive si se borra la corrida
  run                 MarketingRun?  @relation(fields: [runId], references: [id], onDelete: SetNull)
  pillarId            String? // nullable porque puede referir a un pilar SUGERIDO aún no aprobado
  pillar              ContentPillar? @relation(fields: [pillarId], references: [id], onDelete: SetNull)
  suggestedPillarName String? // nullable — nombre del pilar NUEVO propuesto; se linkea al aprobar
  title               String
  copy                String         @db.Text // copy listo para red social
  imageConcept        String         @db.Text // descripción TEXTUAL del concepto de imagen (no se genera)
  selectedAt          DateTime? // nullable porque la idea arranca sugerida; set = "seleccionada" (en trabajo)
  usedAt              DateTime? // nullable; set = "aprobada" (lista para publicar). Estado derivado, ver lib/marketing/schema.ts ideaState()
  discardedAt         DateTime? // nullable; set = "descartada" (rechazada, reversible). Gana sobre selected/used → reabrir vuelve al estado previo
  hubspotDraftAt      DateTime? // nullable; set = ya se envió a HubSpot como borrador social (API broadcast). Ver lib/hubspot/social-broadcast.ts
  hubspotDraftGuids   String[]       @default([]) // broadcastGuid(s) de los borradores creados en HubSpot (uno por canal)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @default(now()) @updatedAt // rastrea la edición manual/IA del copy (default cubre filas existentes)

  sources ContentIdeaSource[]

  @@index([pillarId])
  @@index([createdAt])
}

// Pivote idea ↔ posts que la inspiraron (el agente nunca inventa fuentes).
model ContentIdeaSource {
  id     String          @id @default(cuid())
  ideaId String
  idea   ContentIdea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  postId String
  post   InspirationPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([ideaId, postId])
}

// Idea de campaña (PPC / Google Search) — aprobable / descartable.
model CampaignIdea {
  id          String                  @id @default(cuid())
  runId       String? // nullable porque sobrevive a la corrida
  run         MarketingRun?           @relation(fields: [runId], references: [id], onDelete: SetNull)
  title       String
  channel     CampaignChannel
  description String                  @db.Text // objetivo, audiencia, ángulo, keywords si aplica
  status      MarketingApprovalStatus @default(PENDING)
  reviewedAt  DateTime? // nullable hasta aprobar/descartar
  createdAt   DateTime                @default(now())

  @@index([status, createdAt])
}

// Sugerencia de pilar NUEVO del agente. PENDING → approve (crea ContentPillar) / discard.
model PillarSuggestion {
  id               String                  @id @default(cuid())
  runId            String? // nullable porque sobrevive a la corrida
  run              MarketingRun?           @relation(fields: [runId], references: [id], onDelete: SetNull)
  name             String
  description      String?                 @db.Text
  rationale        String?                 @db.Text // evidencia del agente (posts/insumos que lo motivan)
  status           MarketingApprovalStatus @default(PENDING)
  approvedPillarId String?                 @unique // nullable hasta aprobar — FK al pilar creado
  approvedPillar   ContentPillar?          @relation(fields: [approvedPillarId], references: [id], onDelete: SetNull)
  reviewedAt       DateTime?
  createdAt        DateTime                @default(now())

  @@index([status])
}

// ─── Éxito del cliente (módulo CS) ───────────────────────────────────────────
// Panel /exito-cliente: eventos crudos del cronograma (cola del watchdog),
// alertas triadas por el agente, snapshot de señales HubSpot por cliente, y
// estado de jobs del scheduler. TODO ADITIVO (regla dual-PC).

// Qué entidad del cronograma cambió.
enum CsEventEntity {
  TIMELINE
  PHASE
  TASK
}

// Qué pasó. STATUS_CHANGED cubre suspender (→SUSPENDED); MOVED = cambio de
// semana/orden material; EDITED = otros campos (título, party, type, fechas).
enum CsEventAction {
  STATUS_CHANGED
  CREATED
  DELETED
  MOVED
  EDITED
  ANCHOR_CHANGED
  PROGRESS_APPLIED
  TIMELINE_DELETED
  DETAIL_DELETED
}

// Desde qué superficie se mutó (para que el watchdog distinga edición humana
// granular, guardado bulk del editor, apply de propuesta IA y apply de avance).
enum CsEventSource {
  UI_PATCH
  UI_PUT
  AI_ASSIST_APPLY
  PROGRESS_APPLY
  SYSTEM // mutación automática del sistema (ej. re-anclaje al Kick Off real) — agregado AL FINAL (aditivo)
}

enum CsAlertSeverity {
  LOW
  MEDIUM
  HIGH
}

enum CsAlertCategory {
  TIMELINE_OVERDUE
  TASK_MODIFICATION
  SESSION_MISSED
  PIPELINE_MISMATCH
  ENGAGEMENT_COLD
  SUPPORT_TICKETS
  RENEWAL_RISK
  CHURN_RISK
  EXPANSION_OPPORTUNITY
  PROACTIVE_ACTION
  OTHER
  // CS360 (agregados AL FINAL — ADD VALUE es aditivo, jamás reordenar):
  ADOPTION_RISK // uso bajo / tendencia negativa / adopción baja
  LICENSE_UNUSED // licencias pagadas sin asignar
  PROJECT_BLOCKED // proyecto bloqueado/atrasado según HubSpot (hs_status + motivo)
  // Ciclo de vida:
  STAGE_STALLED // etapa temprana estancada (kickoff sin publicar / cronograma sin consensuar / entendimiento sin cerrar)
}

enum CsAlertStatus {
  OPEN
  SEEN
  RESOLVED
  DISMISSED
}

// Evento CRUDO de mutación del cronograma — lo emiten los endpoints de timeline
// (helper lib/cs/timeline-events.ts). NO reemplaza a TimelineChange (auditoría
// D.3 por snapshot con reason): esto es la COLA del watchdog, granular y barata.
// label denormalizado → el evento se entiende aunque la tarea/fase se haya borrado.
model TimelineEvent {
  id         String        @id @default(cuid())
  projectId  String
  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clientId   String // denormalizado: triage por cliente sin join
  timelineId String? // sin FK dura: el timeline puede borrarse y el evento debe sobrevivir
  entityType CsEventEntity
  entityId   String? // id de la tarea/fase (puede ya no existir)
  label      String // título de tarea / nombre de fase al momento del cambio
  action     CsEventAction
  before     Json? // SOLO los campos que cambiaron (compacto)
  after      Json?
  actorEmail String? // del guard (quién lo hizo)
  source     CsEventSource
  createdAt  DateTime      @default(now())

  // Cola del watchdog: null = pendiente de triage. processedByRunId se setea
  // primero (claim atómico por updateMany); processedAt al cerrar el run.
  processedAt      DateTime?
  processedByRunId String?

  @@index([projectId, processedAt])
  @@index([createdAt])
}

// Alerta TRIADA por el watchdog (agent-cs-watchdog) para la líder de CS.
// El agente decide severidad + razón; el runner deduplica por dedupeKey
// (OPEN/SEEN existente → occurrences++/lastDetectedAt, no fila nueva).
model CsAlert {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId String? // null = alerta a nivel cliente (frialdad, renovación)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  severity        CsAlertSeverity
  category        CsAlertCategory
  title           String
  reason          String          @db.Text // el "por qué" del agente
  suggestedAction String?         @db.Text // acción proactiva propuesta (expansión, rescate…)
  evidence        Json // { eventIds?, taskIds?, dealIds?, sessionIds?, … } para drill

  // Dedup (lo aplica el runner en código; index no-unique a propósito: una
  // alerta RESUELTA vieja puede reaparecer como fila nueva).
  dedupeKey       String
  occurrences     Int      @default(1)
  firstDetectedAt DateTime @default(now())
  lastDetectedAt  DateTime @default(now())

  // Ciclo de vida en el feed.
  status          CsAlertStatus @default(OPEN)
  seenAt          DateTime?
  seenByEmail     String?
  resolvedAt      DateTime?
  resolvedByEmail String?

  agentRunId String?
  agentRun   AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, severity, lastDetectedAt])
  @@index([clientId, status])
  @@index([dedupeKey, status])
}

// Snapshot/cache de señales HubSpot por cliente (1:1). Los Json guardan el crudo
// procesado; los escalares habilitan sort/filtros del panel sin parsear Json.
model ClientCsSignals {
  id          String   @id @default(cuid())
  clientId    String   @unique
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fetchedAt   DateTime @default(now())
  fetchStatus String   @default("ok") // ok | partial | error
  errors      Json? // detalle por señal cuando fetchStatus != ok

  deals      Json? // { open: [...], renewals: [...], expansion: [...] }
  engagement Json? // { lastAt, counts30d/90d, lastItems: [...] }
  tickets    Json? // { supported, open: [...], recent: [...] }

  lastEngagementAt    DateTime?
  engagements90d      Int?
  openTicketCount     Int?
  ticketsSupported    Boolean   @default(false) // false = scope no autorizado (degradación)
  nextRenewalCloseAt  DateTime?
  openExpansionAmount Float?
  openDealCount       Int?

  updatedAt DateTime @updatedAt
}

// CS360 — snapshot del objeto PARTNER CLIENTS de HubSpot (portal de Smarteam como
// Solutions Partner): uso/adopción por hub, licencias, MRR, renovaciones, equipo de
// HubSpot asignado. La clave natural es el record de HubSpot (existe ANTES del match
// con Client); clientId se llena al matchear por Associated Company ID o dominio.
// `properties` guarda el crudo COMPLETO (tolerancia a internal names); los escalares
// se completan desde las properties confirmadas y alimentan charts/sorts sin parsear Json.
// ⚠ El scope del objeto NO está autorizado hoy (403) — el sync degrada con supported:false
// y todo arranca solo al re-autorizar la app OAuth (contrato ticketsSupported).
model ClientPartnerSnapshot {
  id                     String    @id @default(cuid())
  hubspotPartnerClientId String    @unique // id del record partner_clients en HubSpot
  clientId               String?   @unique // null = huérfano transitorio (pre-match)
  client                 Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  fetchedAt              DateTime  @default(now())
  fetchStatus            String    @default("ok") // ok | partial
  properties             Json // crudo completo del record

  domain                 String?
  associatedCompanyIds   String[]  @default([])
  uusScore               Float? // Calificación de uso unificada (UUS)
  // Tendencia últimas 4 semanas. Float directo: sondeado contra los 157 records reales
  // (2026-07-10) — todos los valores no vacíos de hs_last_4_weeks_usage_score_trend son
  // números planos (-0.18…0.01). Tipo endurecido con la tabla en 0 filas (sin migración).
  uusTrend               Float?
  // Componentes del UUS: el portal NO los expone (0 de 172 properties, verificado
  // 2026-07-10). Las columnas quedan por si HubSpot los agrega; hoy siempre null.
  activationScore        Float? // binario 0/100: ¿usó las herramientas core en los primeros 3 meses?
  toolUsageScore         Float? // 0-100: uso activo vs empresas similares
  valueMetricsScore      Float? // 0-100: resultados (deals, contactos, tráfico)
  consumptionScore       Float? // 0-100: consumo de lo pagado (seats/contactos vs límite)
  marketingScore         Float?
  salesScore             Float?
  serviceScore           Float?
  commerceScore          Float?
  seats                  Json? // { core|sales|service: { assigned, available, limit } }
  marketingContactsLimit Int?
  marketingContactsUsed  Int?
  mrrTotal               Float?
  mrrManaged             Float?
  mrrUpForRenewal        Float?
  nextRenewalAt          DateTime?
  renewalsByHub          Json? // { marketing|sales|service|ops: fecha }
  managedExpiryAt        DateTime? // caducidad estimada de la relación gestionada
  cancellationHubs       String? // hubs de próxima cancelación (señal de churn)
  revenueSignal          String? // señal de ingresos (ej. "Límite de créditos")
  revenueSignalDetail    String?   @db.Text // explicación de la señal
  hubEditions            Json? // { marketing|sales|service|ops|content|commerce: edition }
  activeProducts         String? // todos los productos activos
  hsCsmName              String? // Customer Success Manager de HubSpot
  hsCsmEmail             String?
  hsGrowthName           String? // especialista en crecimiento de HubSpot
  hsGrowthEmail          String?
  cslImplementaciones    String? // custom "CSL | Implementaciones"
  country                String?
  portalLink             String? // hs_account_link: deep-link al portal del cliente en HubSpot

  updatedAt DateTime @updatedAt
}

// CS360 — HISTORIAL semanal de uso por partner client (el UUS se recalcula
// semanalmente en HubSpot): una fila por (record, semana ISO) — el sync diario
// upsertea la fila de la semana en curso, así queda la última foto de cada semana.
// Permite calcular tendencia PROPIA (subiendo/bajando/estancado) más allá del
// campo de tendencia que reporta HubSpot. CONFIDENCIAL (términos de partner):
// solo superficies internas CSL/SUPER_ADMIN, jamás vistas externas del cliente.
model PartnerUsageSnapshot {
  id                     String   @id @default(cuid())
  hubspotPartnerClientId String // record de partner_clients (sin FK dura)
  clientId               String? // denormalizado al momento de la captura
  weekKey                String // "YYYY-Www" (semana ISO)
  capturedAt             DateTime @default(now())
  uusScore               Float?
  activationScore        Float?
  toolUsageScore         Float?
  valueMetricsScore      Float?
  consumptionScore       Float?
  marketingScore         Float?
  salesScore             Float?
  serviceScore           Float?
  marketingContactsUsed  Int?
  marketingContactsLimit Int?
  seats                  Json?
  mrrTotal               Float?
  nextRenewalAt          DateTime?

  @@unique([hubspotPartnerClientId, weekKey])
  @@index([clientId, weekKey])
}

// CS360 — resumen ejecutivo POR CUENTA generado por agente (agent-cs-account-brief,
// prompt en DB). Cada statement CITA su fuente con fecha ("Minuta kickoff · 2 jul",
// "HubSpot Partner · hoy") — regla dura: sin fuente no hay afirmación. staleAt lo
// marca el partner-sync cuando cambian los inputs; la regeneración es on-demand.
model CsAccountBrief {
  id          String    @id @default(cuid())
  clientId    String    @unique
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  headline    String?   @db.Text // una línea: el estado de la cuenta
  statements  Json // [{ text, source: { kind, id, label, date } }]
  agentRunId  String? // AgentRun que lo generó (trazabilidad)
  generatedAt DateTime  @default(now())
  staleAt     DateTime? // inputs cambiaron después de generar → banner "desactualizado"
  updatedAt   DateTime  @updatedAt
}

// Config singleton del módulo CS (id="cs"). watchdogEnabled = kill-switch en DB
// (apagar el watchdog sin redeploy). El estado de cron vive en CronJobState.
model CsSettings {
  id              String   @id @default("cs")
  watchdogEnabled Boolean  @default(true)
  // Ciclo de vida — umbral UUS (0-100) para dar por cumplida VALIDACION_USO (gate
  // USO_VALIDADO). Política global del módulo, como watchdogEnabled.
  uusValidationThreshold Float @default(60)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Estado genérico de jobs del scheduler (lib/jobs) — claim atómico anti-doble-fire
// por compare-and-set de lastRunDateKey (patrón de MarketingSettings.lastCronDateKey,
// generalizado por jobKey). Marketing conserva su claim propio por ahora.
model CronJobState {
  id             String    @id // jobKey ("cs-signals", "cs-watchdog-daily", …)
  lastRunDateKey String? // "YYYY-MM-DD" (día CR) del último disparo
  lastRunAt      DateTime?
  // Resultado del último run CONCLUYENTE del job (lo escribe el propio job, no el
  // scheduler). Primer uso: fila `cs-partner-sync-status` con {supported, total,
  // matched, unmatched, error?, at} — las corridas locked/transitorias NO lo pisan.
  // Es la fuente de verdad de "¿el scope está autorizado?" para los paneles de CS.
  lastResult     Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ═══════════════════════════════════════════════════════════════════════════════
// ═══ COBRANZA — control de cartera de cobros (Admin & Finanzas) ════════════════
// ═══════════════════════════════════════════════════════════════════════════════
// Nexus es la capa de CONTROL de cobros ("¿a quién le toca cobrar y cómo va?");
// la facturación fiscal, conciliación bancaria y contabilidad viven en Odoo/Mercury
// (ver docs/DECISIONS.md § Cobranza). Acceso: SOLO roles ADMIN + SUPER_ADMIN
// (whitelist lib/auth/cobranza-roles.ts, enforcement server-side).
//
// NAMING EN ESPAÑOL A PROPÓSITO (desviación deliberada de la convención inglesa
// del resto del schema): el dominio se opera en español (Alex/Finanzas) y los
// términos (cobro, cuota, arranque, catch-up) no traducen 1:1 sin perder
// precisión. Documentado en DECISIONS — no "corregir" a inglés.

enum CobranzaTipoCuenta {
  NACIONAL
  INTERNACIONAL
}

enum CobranzaViaCobro {
  MERCURY
  ODOO
  OTRA
}

enum CobranzaMoneda {
  CRC
  USD
}

enum CobranzaTerminosPago {
  ANTICIPADO
  VENCIDO
}

enum CobranzaEstadoCuenta {
  PENDIENTE_DATOS // falta info para operar (ej. sin fecha de arranque) — no genera cobros
  PENDIENTE_CONTRATO
  ACTIVA
  CON_ATRASO
  SUSPENDIDA
}

enum CobranzaTipoServicio {
  SUSCRIPCION
  IMPLEMENTACION
  WEB
  SOPORTE
  CRM
  OTRO
}

enum CobranzaModalidad {
  RECURRENTE // sin fin (suscripciones)
  PROYECTO // con fin (implementaciones)
}

enum CobranzaEstadoServicio {
  ACTIVO
  FINALIZADO
  PAUSADO
}

enum CobranzaPlanTemplate {
  PAREJO // N cuotas iguales mensuales desde el arranque
  ENTRADA_Y_RESTO // entrada X% + resto parejo en N cuotas
  SUSCRIPCION // recurrente mensual sin fin (rolling)
  PERSONALIZADO // cuotas arbitrarias (% o monto fijo + offset)
}

enum CobranzaPlanOrigen {
  AUTO_HANDOFF // pre-configurado desde el contexto de ventas (Fase 3 — enum listo, v1 no lo usa)
  MANUAL
}

enum CobranzaCuotaBase {
  PORCENTAJE // valor = % del montoTotal (0-100)
  MONTO_FIJO // valor = monto absoluto
}

enum CobranzaEstadoCobro {
  PROGRAMADO // futuro según plan (semáforo gris) o catch-up pendiente de revisión
  POR_COBRAR // toca cobrarlo / factura en curso (amarillo)
  COBRADO // plata entró — EXIGE confirmadoPor (INV3; verde)
  SIN_DATO // falta info para determinarlo (cero fabricación)
}

enum CobranzaOrigenCobro {
  PLAN // materializado desde PlanDePago
  CATCH_UP // generado por desfase arranque-vs-hoy (caso Teamnet) — requiere confirmación
  MANUAL // creado a mano por la persona
}

enum CobranzaTipoAlerta {
  COBRO_PROXIMO // falta facturar, en ventana (Tanda B: reencuadrado a los dos relojes)
  FACTURACION_ATRASADA // falta facturar, pasó la gracia — trabajo pendiente de Alex, no mora del cliente
  COBRO_VENCIDO // ya facturado, se venció el crédito (fechaEmision + creditoDias) sin cobrar
  CUENTA_SIN_DATOS // cliente con proyecto sin cuenta/servicios/arranque
  INCONSISTENCIA_CICLO // catch-up generado pendiente de confirmación
  ARRANQUE_CAMBIADO // fechaInicioFacturacion divergió del anchorStartDate actual
  MONTOS_DESCUADRADOS // plan activo cuya expansión no suma el montoTotal (aviso, no invariante)
  PROMESA_INCUMPLIDA // la promesa de pago pasó sin que el cobro llegara a COBRADO
}

enum CobranzaUrgencia {
  ALTA
  MEDIA
  BAJA
}

enum CobranzaAlertaEstado {
  ABIERTA
  VISTA
  RESUELTA
  DESCARTADA
}

enum BitacoraCobroTipo {
  LLAMADA
  CORREO
  NOTA
  ACTUALIZACION_IA // escrita por el sistema (ej. resumen de una materialización)
}

// ─── CuentaFinanciera ───────────────────────────────────────────────────────────
// Perfil de cobro de un cliente (1:1 con Client — idioma ClientCsSignals). Concern
// separado del Client operativo: acá vive TODO lo que Finanzas necesita saber.
model CuentaFinanciera {
  id       String @id @default(cuid())
  clientId String @unique
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  tipo          CobranzaTipoCuenta   @default(NACIONAL)
  viaCobro      CobranzaViaCobro     @default(ODOO)
  moneda        CobranzaMoneda       @default(CRC)
  // DEPRECATED — reemplazado por creditoDias (Tanda B, 2026-07). Nunca alimentó
  // ningún cálculo del motor (0 lectores en engine.ts). Se mantiene escribible
  // (importador, alta manual) para no romper esos caminos sin necesidad; sacado
  // de los 2 formularios de configuración de cuenta.
  terminosPago  CobranzaTerminosPago @default(ANTICIPADO)
  diaCobroAncla Int? // nullable porque el día del ciclo puede no estar definido aún (ej. 15, 16)
  // nullable → cae a DEFAULT_CREDITO_DIAS (engine.ts) cuando la cuenta no trae el
  // suyo. Días de crédito otorgados al cliente desde que se emite la factura
  // (Reloj 2 del semáforo — Tanda B). Normal 15, Colby 90.
  creditoDias   Int?
  estadoCuenta  CobranzaEstadoCuenta @default(PENDIENTE_DATOS)
  // Caso Colby: cuenta fuera del estándar — oculta del panel y del cronograma automático.
  excluidaOperacion        Boolean @default(false)
  // Licencias de terceros (ej. Hotspot): el cliente paga directo al tercero — esto
  // documenta qué explicarle. nullable porque solo aplica a esos casos.
  responsableCobroTerceros String?
  notas                    String? @db.Text
  // Curaduría manual del estado (idioma healthStatusOverride{By,At}): quién/cuándo
  // cambió estadoCuenta a mano por última vez (email del guard).
  estadoActualizadoPor String?
  estadoActualizadoEn  DateTime?
  // Procedencia (regla fuente + id_externo — upsert idempotente del importador).
  // null = cuenta configurada a mano desde el panel antes de esta regla.
  fuente          String? // "manual" | "sheet" (futuro: "hubspot" | "odoo")
  fuenteIdExterno String?
  // Correo al que se le cobra (destino del mailto del borrador de cobro).
  // nullable porque el import puede no traerlo — se completa a mano.
  correoCobro     String?
  // Identidad legal (razón social + cédula jurídica), distinta del nombre
  // comercial (Client.name). nullable porque no toda cuenta tiene esta
  // identidad legal capturada aún — se completa a mano o vía el importador
  // del histórico. Sin @unique en cedulaJuridica: un mismo holding puede
  // facturar bajo varios nombres comerciales con la misma cédula (ver
  // DECISIONS.md).
  razonSocial     String?
  cedulaJuridica  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  servicios ServicioContratado[]
  cobros    Cobro[] // vía cuentaId denormalizado en Cobro (panel sin doble join)
  alertas   AlertaCobro[]
  bitacora  BitacoraCobro[]

  @@unique([fuente, fuenteIdExterno]) // NULLs no colisionan — las cuentas manuales legacy conviven
  @@index([estadoCuenta])
}

// ─── ServicioContratado ─────────────────────────────────────────────────────────
// Un servicio facturable de la cuenta (un contrato puede traer varios: suscripción
// perpetua + implementación de 4 meses). Cada uno lleva su propio plan y cronograma.
model ServicioContratado {
  id       String           @id @default(cuid())
  cuentaId String
  cuenta   CuentaFinanciera @relation(fields: [cuentaId], references: [id], onDelete: Cascade)

  tipoServicio CobranzaTipoServicio
  modalidad    CobranzaModalidad
  // Dinero: primer uso de Decimal en el repo (a propósito — Float acumula error en
  // montos). Prisma.Decimal NO cruza a Client Components: se serializa a number en
  // lib/cobranza/queries.ts (único punto). Para SUSCRIPCION = monto MENSUAL.
  montoTotal Decimal        @db.Decimal(12, 2)
  moneda     CobranzaMoneda
  // COPIA EDITABLE del ancla: default = ProjectTimeline.anchorStartDate del proyecto
  // al configurar (se LEE una vez, no se sincroniza). Si el CSE cambia el arranque
  // después, la divergencia la detecta la alerta ARRANQUE_CAMBIADO — nunca se
  // regeneran cobros emitidos/cobrados. nullable: sin ancla ⇒ PENDIENTE_DATOS, sin cobros.
  fechaInicioFacturacion DateTime?
  duracionMeses          Int? // nullable porque las suscripciones abiertas no tienen fin
  projectId              String? // nullable porque puede haber servicios sin proyecto en Nexus
  project                Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  estado                 CobranzaEstadoServicio @default(ACTIVO)
  descripcion            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  planes PlanDePago[]
  cobros Cobro[]

  @@index([cuentaId, estado])
  @@index([projectId])
}

// ─── PlanDePago ─────────────────────────────────────────────────────────────────
// El "arreglo de pago" con que se vendió el monto. NO es siempre monto÷N: plantillas
// configurables. Solo 1 activo por servicio (lo garantiza setPlanActivo por transacción).
model PlanDePago {
  id         String             @id @default(cuid())
  servicioId String
  servicio   ServicioContratado @relation(fields: [servicioId], references: [id], onDelete: Cascade)

  template  CobranzaPlanTemplate
  origen    CobranzaPlanOrigen @default(MANUAL)
  numCuotas Int? // nullable porque SUSCRIPCION no tiene N fijo
  activo    Boolean            @default(true)
  notas     String?            @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cuotas CuotaPlan[]
  cobros Cobro[] // trazabilidad: de qué plan salió cada cobro materializado

  @@index([servicioId, activo])
}

// ─── CuotaPlan ──────────────────────────────────────────────────────────────────
// La definición de cada cuota del plan (para PERSONALIZADO; las plantillas simples
// las expanden en el engine sin filas explícitas salvo la entrada de ENTRADA_Y_RESTO).
model CuotaPlan {
  id          String     @id @default(cuid())
  planId      String
  plan        PlanDePago @relation(fields: [planId], references: [id], onDelete: Cascade)
  orden       Int // 1-based
  base        CobranzaCuotaBase
  valor       Decimal    @db.Decimal(12, 2) // 0-100 si PORCENTAJE; monto absoluto si MONTO_FIJO
  offsetMeses Int        @default(0) // 0 = mes de arranque
  descripcion String?

  @@unique([planId, orden])
}

// ─── Cobro ──────────────────────────────────────────────────────────────────────
// El corazón del módulo: una obligación de cobro concreta, materializada desde el
// plan (o catch-up/manual). INV3: estado=COBRADO exige confirmadoPor (chokepoint
// lib/cobranza/mutations.ts#cambiarEstadoCobro; red dura en check-invariants.ts).
model Cobro {
  id         String             @id @default(cuid())
  servicioId String
  servicio   ServicioContratado @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  cuentaId   String // denormalizado: última/próxima fecha del panel sin doble join
  cuenta     CuentaFinanciera   @relation(fields: [cuentaId], references: [id], onDelete: Cascade)
  planId     String? // nullable porque los MANUAL pueden no salir de un plan
  plan       PlanDePago?        @relation(fields: [planId], references: [id], onDelete: SetNull)

  // El engine SIEMPRE asigna numCuota; los MANUAL van null. En Postgres los NULL no
  // colisionan en el unique compuesto → los manuales conviven sin límite y los del
  // engine quedan protegidos contra duplicación (idempotencia). NO "arreglar" con
  // un unique parcial.
  numCuota        Int?
  periodo         String // "YYYY-MM" (mes calendario UTC que cubre)
  fechaProgramada DateTime // fecha de CALENDARIO como instante UTC (patrón anchorStartDate)
  monto           Decimal  @db.Decimal(12, 2)
  moneda          CobranzaMoneda
  estado          CobranzaEstadoCobro @default(PROGRAMADO)
  origen          CobranzaOrigenCobro @default(PLAN)
  fechaEmision    DateTime? // cuándo se emitió la factura (en Odoo/Mercury)
  // Auditoría de "Marcar facturado" (Tanda B) — mismo patrón que confirmadoPor/
  // confirmadoEn: se setea cuando fechaEmision pasa de null a no-null, se limpia
  // al revertir. nullable porque solo tiene valor mientras fechaEmision existe.
  facturadoPor    String?
  facturadoEn     DateTime?
  fechaCobro      DateTime? // cuándo entró la plata
  confirmadoPor   String? // email del guard que confirmó el estado con consecuencia monetaria
  confirmadoEn    DateTime?
  // ReconciliationPort v1: referencia externa OPCIONAL al confirmar COBRADO (id de
  // transacción Mercury / factura Odoo). Solo metadata — la conciliación real vive allá.
  referenciaExterna String?
  // Promesa de pago: calla COBRO_VENCIDO y COBRO_PROXIMO de ESTE cobro hasta la
  // fecha (semáforos y métricas NO cambian — honestidad); pasada sin COBRADO →
  // alerta PROMESA_INCUMPLIDA. nullable porque la mayoría no tiene promesa.
  promesaPago     DateTime?
  notas           String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([servicioId, numCuota])
  @@index([cuentaId, fechaProgramada])
  @@index([estado, fechaProgramada])
}

// ─── AlertaCobro ────────────────────────────────────────────────────────────────
// Alerta generada por el cómputo de cartera (clon del ciclo de vida de CsAlert):
// dedup por dedupeKey (merge si sigue ABIERTA/VISTA; supresión 7d si RESUELTA/DESCARTADA).
model AlertaCobro {
  id       String           @id @default(cuid())
  cuentaId String
  cuenta   CuentaFinanciera @relation(fields: [cuentaId], references: [id], onDelete: Cascade)
  cobroId  String? // nullable porque CUENTA_SIN_DATOS es a nivel cuenta (sin cobro)

  tipo      CobranzaTipoAlerta
  urgencia  CobranzaUrgencia
  mensaje   String @db.Text
  evidencia Json? // { cobroIds?, servicioId?, fechas? } para drill desde la UI

  // Index no-unique a propósito: una alerta RESUELTA vieja puede reaparecer como fila nueva.
  dedupeKey       String
  occurrences     Int      @default(1)
  firstDetectedAt DateTime @default(now())
  lastDetectedAt  DateTime @default(now())

  estado      CobranzaAlertaEstado @default(ABIERTA)
  vistaEn     DateTime?
  vistaPor    String? // email del guard
  resueltaEn  DateTime?
  resueltaPor String? // email del guard
  // Snooze manual (o auto-snooze al registrar promesa de pago): loadAlertas la
  // excluye hasta esta fecha; el merge del upsert NO la resucita. No cambia estado.
  posponerHasta DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estado, urgencia, lastDetectedAt])
  @@index([cuentaId, estado])
  @@index([dedupeKey, estado])
}

// ─── SnapshotCartera ────────────────────────────────────────────────────────────
// Foto del set de alertas de cada corrida del corte (lunes o disparo manual). El
// digest semanal es el DIFF contra la corrida anterior — si nada cambió, no molesta.
// Fila-por-corrida con payload Json (no hash): el demo puede correr N veces el mismo
// día sin colisión y el digest histórico queda legible. ~52 filas/año — trivial.
model SnapshotCartera {
  id          String   @id @default(cuid())
  capturedAt  DateTime @default(now())
  alertSet    Json // [{ dedupeKey, tipo, urgencia, cuentaId, cobroId?, mensaje }]
  resumen     Json // digest computado: { nuevas, resueltas, persistentes, sinCambios }
  // FASE 3: métricas agregadas del corte (shape MetricasCartera del engine, con
  // `version`). Json EXTENSIBLE a propósito — el día que se absorba tesorería
  // (FX realizado, burn) se agregan llaves sin tocar schema. null = snapshot
  // pre-fase-3 (SIN backfill — la serie histórica arranca de cero hacia adelante).
  metricas    Json?
  triggeredBy String? // "cron" | email del disparo manual

  @@index([capturedAt])
}

// ─── BitacoraCobro ──────────────────────────────────────────────────────────────
// Registro de gestión de la cuenta (llamadas, correos, notas de la persona +
// actualizaciones automáticas del sistema como los resúmenes de materialización).
model BitacoraCobro {
  id           String           @id @default(cuid())
  cuentaId     String
  cuenta       CuentaFinanciera @relation(fields: [cuentaId], references: [id], onDelete: Cascade)
  cobroId      String? // nullable porque hay entradas a nivel cuenta
  tipo         BitacoraCobroTipo
  contenido    String  @db.Text
  usuarioEmail String? // nullable porque ACTUALIZACION_IA no tiene usuario
  createdAt    DateTime @default(now())

  @@index([cuentaId, createdAt])
}

enum CobranzaImportEstado {
  BORRADOR // subido + parseado; mapeo en curso
  EN_REVISION // mapeo aplicado; cola de revisión abierta
  APLICADO
  DESCARTADO
}

enum CobranzaImportFilaEstado {
  VALIDA // pasa Zod + dedup resuelto → se aplicará
  REVISAR // inválida o dudosa → edición inline en la cola
  APLICADA
  OMITIDA // descartada a mano por la persona
}

// ─── ImportacionCobranza (staging del importador CSV) ───────────────────────────
// Un batch por archivo subido. El mapeo columna→campo canónico vive acá (Json
// configurable — NO cableado al Excel de Alex: el modelo canónico manda). Las
// filas inválidas NUNCA se ingieren en silencio: quedan REVISAR hasta corregirse
// u omitirse. AccountSource "sheet" del puerto 1 (lib/cobranza/ports.ts).
model ImportacionCobranza {
  id            String               @id @default(cuid())
  archivoNombre String
  fuente        String               @default("sheet") // se estampa en Client.source / CuentaFinanciera.fuente
  mapeo         Json // { campoCanonico: nombreColumnaCSV } — editable en el wizard
  columnas      Json // string[] headers detectados por el parser
  estado        CobranzaImportEstado @default(BORRADOR)
  totalFilas    Int                  @default(0)
  creadoPor     String // email del guard
  aplicadoEn    DateTime? // nullable porque solo se setea al aplicar
  aplicadoPor   String?
  resumen       Json? // { clientsCreados, cuentasCreadas, cuentasVinculadas, serviciosCreados, omitidas, fallidas }
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  filas ImportacionFila[]
}

// ─── ImportacionFila ────────────────────────────────────────────────────────────
// Una fila del CSV: cruda (raw) + canónica (post-mapeo/edición) + resultado del
// dedup. `dedup` es Json a propósito (sugerencia efímera de staging, no vínculo
// durable) — la FK real es aplicadoClientId, que se setea recién al aplicar.
model ImportacionFila {
  id       String              @id @default(cuid())
  importId String
  import   ImportacionCobranza @relation(fields: [importId], references: [id], onDelete: Cascade)

  numFila   Int // 1-based en el CSV
  raw       Json // fila cruda parseada { header: valor }
  canonico  Json? // payload canónico (shape importFilaCanonicaSchema) — post-mapeo + ediciones inline
  estado    CobranzaImportFilaEstado @default(REVISAR)
  errores   Json? // string[] mensajes de validación (Zod + reglas de negocio)
  dedup     Json? // { clientId, tipo: "fuente_id"|"dominio"|"nombre_exacto", clienteNombre } | null
  idExterno String? // id estable resuelto (columna id del sheet o slug del nombre)

  aplicadoClientId String? // nullable porque solo se setea al aplicar
  aplicadoClient   Client? @relation(fields: [aplicadoClientId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([importId, numFila])
  @@index([importId, estado])
}

enum CobranzaCategoriaCosto {
  SALARIO
  HERRAMIENTA
  FIJO_OPERACION
}

enum CobranzaFrecuenciaCosto {
  MENSUAL
  ANUAL // se proyecta mensualizado (/12)
}

// ─── CostoRecurrente ────────────────────────────────────────────────────────────
// REGISTRO DE REFERENCIA ESTIMADO de costos recurrentes (burn aproximado) para la
// caja neta (entra − sale). NO es contabilidad/planilla/facturación: cero lógica
// fiscal CR (CCSS/cargas/aguinaldo/renta), cero sociedades, cero tracking de pago
// (un costo no tiene "pagado" ni semáforo — no vence). El CANÓNICO es `monto`
// (all-in estimado); montoBase/factorCargas son memoria del helper de entrada de
// salarios y el motor JAMÁS los lee. PRIVACIDAD DURA: superficie SOLO SUPER_ADMIN
// (COSTOS_ROLES + guardCostosAccess, 3 capas server-side — RLS no cuenta: Prisma
// bypassa) — los salarios son la información más sensible del sistema y por eso
// viven en entidad APARTE, nunca como columna de TeamMember.
model CostoRecurrente {
  id         String                  @id @default(cuid())
  categoria  CobranzaCategoriaCosto
  nombre     String
  // Monto ALL-IN ESTIMADO (lo único que proyecta el motor), en su frecuencia.
  monto      Decimal                 @db.Decimal(12, 2)
  moneda     CobranzaMoneda
  frecuencia CobranzaFrecuenciaCosto @default(MENSUAL)

  // nullable porque solo SALARIO liga persona (y un salario puede registrarse sin
  // TeamMember, ej. contratación en curso). onDelete SetNull: dar de baja a la
  // persona NO borra la historia de costos — el costo queda sin vínculo y quien
  // mantiene Finanzas lo pausa o borra a mano.
  teamMemberId String?
  teamMember   TeamMember? @relation("CostosDePersona", fields: [teamMemberId], references: [id], onDelete: SetNull)

  // Memoria del helper base+factor — NO es lógica fiscal: factorCargas es un
  // multiplicador EDITABLE por el usuario (ej. 1.35), cero tasas hardcodeadas.
  // Van juntos o ninguno; solo sirven para reabrir el form en ese modo.
  montoBase    Decimal? @db.Decimal(12, 2)
  factorCargas Decimal? @db.Decimal(6, 4)

  activo Boolean @default(true) // false = pausado (fuera de la proyección, sin borrar)
  notas  String? @db.Text

  // Baja DEFINITIVA (renuncia/desvinculación/cancelación) — distinta de la pausa
  // (activo=false, temporal). El motor proyecta el costo hasta el bucket que
  // CONTIENE esta fecha (entero, sin prorrateo diario — es referencia) y lo
  // excluye después; pasada la fecha sale del burn. nullable porque un costo
  // vigente no tiene baja.
  finalizadoEl DateTime? @db.Date

  movimientos CostoMovimiento[] @relation("MovimientosDeCosto")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([activo, categoria])
}

enum CostoMovimientoTipo {
  ALTA
  BAJA // finalizadoEl seteado (baja definitiva, ≠ pausa)
  REACTIVACION // finalizadoEl limpiado, o activo false→true
  PAUSA // activo true→false
  CAMBIO_MONTO
  ELIMINACION // hard delete — la última huella (queda con costoId null)
}

// ─── CostoMovimiento ─────────────────────────────────────────────────────────
// Historia APPEND-ONLY de altas/bajas/cambios de los costos recurrentes (patrón
// BitacoraCobro). La escriben SOLO las mutations de costos, en la misma
// transacción — nunca desde la UI. Lleva un SNAPSHOT autosuficiente
// (nombre/categoria/moneda/frecuencia/monto) para leerse sola aunque el costo
// cambie o se borre (hard delete → costoId queda null vía SetNull).
// ⚠ PRIVACIDAD: lleva montos de SALARIOS — mismas 3 capas + RLS deny que
// CostoRecurrente. JAMÁS se expone fuera de las superficies SUPER_ADMIN.
model CostoMovimiento {
  id String @id @default(cuid())
  // nullable porque la historia SOBREVIVE al hard delete del costo (SetNull).
  costoId String?
  costo   CostoRecurrente? @relation("MovimientosDeCosto", fields: [costoId], references: [id], onDelete: SetNull)

  tipo CostoMovimientoTipo

  // Snapshot del costo al momento del movimiento (autosuficiente).
  nombre     String
  categoria  CobranzaCategoriaCosto
  moneda     CobranzaMoneda
  frecuencia CobranzaFrecuenciaCosto
  monto      Decimal                 @db.Decimal(12, 2) // monto DESPUÉS del movimiento, en su frecuencia
  // nullable porque solo CAMBIO_MONTO lo lleva.
  montoAnterior Decimal? @db.Decimal(12, 2)

  fechaEfectiva DateTime @db.Date // cuándo ocurrió de verdad (retroactiva permitida)
  usuarioEmail  String? // nullable por simetría con BitacoraCobro (hoy siempre viene del guard)
  notas         String? @db.Text // motivo libre ("renuncia", "desvinculación", "contratación")

  createdAt DateTime @default(now())

  @@index([fechaEfectiva])
  @@index([costoId, createdAt])
}

// ─── GastoPuntual ────────────────────────────────────────────────────────────
// Gasto ÚNICO/circunstancial de REFERENCIA estimada (compra de equipo, evento,
// mantenimiento) — MISMA línea dura que CostoRecurrente: no es contabilidad, sin
// estado de pago (fecha pasada = ejecutado; futura = compra planificada → entra a
// la caja neta en el bucket de su fecha), sin lógica fiscal, sin FX. Los `tags`
// son vocabulario ABIERTO normalizado a slug al escribir (normalizeGastoTag en
// lib/cobranza/schema.ts) — NO usa el catálogo cerrado de proyectos.
// ⚠ PRIVACIDAD: superficie SOLO SUPER_ADMIN (guardCostosAccess) + RLS deny.
model GastoPuntual {
  id     String         @id @default(cuid())
  nombre String
  monto  Decimal        @db.Decimal(12, 2)
  moneda CobranzaMoneda
  fecha  DateTime       @db.Date // día del gasto (único campo temporal con semántica)
  tags   String[]       @default([])
  notas  String?        @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fecha])
}

// ── Roles (roles y responsabilidades del equipo) ────────────────────────────────
// Perfil de PUESTO libre (no atado al enum TeamRole ni a un TeamMember) que se
// documenta a mano y se renderiza como una página web resumida. Plantilla fija de
// 6 secciones en markdown. Sin IA. Superficie SOLO SUPER_ADMIN (docs internos de
// dirección) — RLS deny (tabla interna, sin policy SELECT).
model RoleProfile {
  id             String  @id @default(cuid())
  title          String // nombre del puesto (ej. "CSE", "Asistente de Finanzas")
  area           String? // área/equipo (ej. "Customer Success") — opcional
  summary        String? @db.Text // resumen de 1 línea (subtítulo del hero)
  // Contenido estructurado por sección: mapa { [sectionKey]: data } que consume el
  // motor de landing (LandingView + config de roles). Reemplaza las 7 columnas markdown
  // (perfil/responsabilidades/kpis/éxito/fracaso/madurez/transición) — cada sección
  // guarda su propio shape (prose {md}, cards {items}, kpis, niveles). Ver
  // components/landing/configs/roles.defs.ts. Reusa la PRESENTACIÓN/EDICIÓN del motor,
  // NO el motor de datos (ProjectCanvas/CanvasBlock) — decisión en docs/DECISIONS.md.
  content        Json    @default("{}")
  active         Boolean @default(true)
  order          Int     @default(0)
  createdByEmail String? // quién lo creó (auditoría liviana)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, order])
}
