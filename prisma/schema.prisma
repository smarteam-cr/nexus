generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ImplementationStatus {
  PLANNING
  READY
  EXECUTING
  DONE
  PAUSED
}

enum ExecutionStatus {
  SUCCESS
  FAILED
  MANUAL_REQUIRED
  SKIPPED
}

enum DocumentType {
  CALL_TRANSCRIPT
  BRIEF
  FREE_TEXT
  URL
  FILE
}

enum AgentStatus {
  ACTIVE
  DRAFT
}

enum AgentRunStatus {
  PENDING
  RUNNING
  DONE
  ERROR
  ARCHIVED
}

enum AgentOutputType {
  CARDS
  STREAM
  FLOWCHART
  CARDS_AND_FLOWCHARTS
  CARDS_AND_CHARTS
  AUDIT_REPORT
}

enum AgentScope {
  CLIENT
  GLOBAL
}

enum AgentType {
  SECTION           // Agente de subetapa — genera cards/flowcharts para una sección
  CANVAS_PROJECT    // Agente transversal — actualiza canvas de proyecto
  CANVAS_CLIENT     // Agente transversal — actualiza canvas de empresa
  SESSION_PROCESSOR // Agente de procesamiento de sesión — lee Fireflies y genera cards
}

enum ProjectType {
  BASE_IMPLEMENTATION // Implementación base — activación de herramientas, superficial y general
  USE_CASE            // Caso de uso — específico y profundo, resolución de un reto particular
}

// El agente de handoff lo infiere (¿el cliente ya usa HubSpot?); el CSE puede corregirlo.
// Define qué plantilla de fases/tareas usa el cronograma (uso futuro). Interno.
enum ImplementationType {
  IMPLEMENTATION   // Nueva implementación — el cliente arranca con HubSpot por primera vez
  REIMPLEMENTATION // Re-implementación — ya usa HubSpot o viene de otro CRM
}

enum CardSource {
  AGENT    // Generada íntegramente por el agente
  HUMAN    // Creada manualmente por el consultor
  MODIFIED // Generada por el agente y luego editada por el consultor
}

enum CardType {
  TEXT      // Card de texto (default)
  FLOWCHART // Diagrama de React Flow (nodos + edges guardados en diagramData)
  CHART     // Gráfico de ECharts (configuración en chartConfig)
}

// ─── Block system (canvases no-default) ─────────────────────────────────────

enum BlockType {
  TEXT
  HEADING
  TABLE
  METRIC
  CALLOUT
  CARD
  FLOWCHART
  CHART
  IMAGE
}

enum BlockSource {
  AGENT
  HUMAN
  MODIFIED // generado por IA, editado por un humano (CSE)
}

enum BlockStatus {
  DRAFT
  CONFIRMED
}

// ─── Business Cases (Ventas) ─────────────────────────────────────────────────

enum BusinessCaseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BusinessCaseBlockType {
  HERO
  PAIN_POINTS
  BEFORE_AFTER
  SOLUTION
  ROI_METRICS
  TIMELINE
  INVESTMENT
  PARTNER
  CTA
}

enum BusinessCaseTranscriptSource {
  PASTED
  UPLOADED
}

// ─── Client (nueva entidad raíz) ──────────────────────────────────────────────

model Client {
  id               String   @id @default(cuid())
  name             String
  company          String?
  industry         String?
  notes            String?  @db.Text
  hubspotCompanyId String?  // ID de la empresa vinculada en HubSpot CRM
  emailDomains     String[] // dominios de email para matching automático de sesiones (ej: "ice.go.cr")
  logoUrl          String?  // URL pública del logo del cliente (bucket public-assets) — se muestra en kickoff/cronograma externos
  // Prospecto de Ventas: Client creado lazily desde una empresa HubSpot para un
  // business case (puede no ser cliente real todavía). Se EXCLUYE de los listados
  // de CS (clientes, sidebar, portafolio).
  isProspect       Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  canvas           Json?   // Client Canvas — conocimiento a nivel empresa
  canvasConfidence Json?   // { section: "confirmed" | "inferred" } per section

  hubspotAccount    HubspotAccount?
  audits            Audit[]
  implementations   Implementation[]
  knowledge         Knowledge[]
  documents         ClientDocument[]
  stageNotes        StageNote[]
  agentRuns         AgentRun[]
  contextCards      ClientContextCard[]
  projects          Project[]
  canvasSuggestions CanvasSuggestion[]
  actionItems       ActionItem[]
  appUsers          AppUser[]              // F2: usuarios externos vinculados (kind=EXTERNAL)
  assignments       ClientAssignment[]     // F2: overrides manuales CSE↔Cliente
  handoffs          Handoff[]              // entidad Handoff (1:N por cliente, ver model Handoff)
  businessCases     BusinessCase[]         // Ventas: casos de negocio (1:N por cliente)
}

// ─── SystemConfig (config GLOBAL de Nexus, singleton — no por usuario) ─────────
// Un solo row (id="system"; se upsert). Hoy guarda el logo de Smarteam
// configurable (se muestra en el chrome externo, con fallback a /logo-smarteam.png).
model SystemConfig {
  id              String   @id @default("system")
  smarteamLogoUrl String?  // URL pública del logo de Smarteam (bucket public-assets)
  hubspotLogoUrl  String?  // logo de HubSpot — brand-row de business cases + kickoffs
  insiderLogoUrl  String?  // logo de Insider One — ídem
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Project ──────────────────────────────────────────────────────────────────

model Project {
  id               String  @id @default(cuid())
  clientId         String
  client           Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name             String
  status           String  @default("active") // active | paused | completed
  projectType      ProjectType @default(USE_CASE) // Tipo de proyecto: implementación base o caso de uso
  implementationType ImplementationType? // ¿nueva impl o re-impl? Lo infiere el handoff; el CSE corrige. Interno (no cruza al cliente).
  serviceType      String? // loop_marketing | loop_sales | loop_service | proyecto_temporal
  hubspotDealId    String? // ID del deal de HubSpot asociado a este proyecto
  hubspotServiceId String? @unique // ID del objeto Service en HubSpot (para sync)
  currentStage     Int     @default(1) // Última etapa visitada/modificada (1-3)
  currentStep      Int     @default(0) // Último paso visitado/modificado dentro de la etapa (0-indexed)
  canvas           Json?   // DEPRECATED — ya no se lee para renderizar el canvas
  tags             String[] @default([]) // Tags generales del proyecto (e.g. "Marketing Hub", "Sales Hub")
  shareToken       String?  @unique     // Token para vista pública del cliente

  // GPS del proyecto
  nextSessionDate    DateTime? // LEGACY (project-wide) — reemplazado por los overrides por frente de abajo
  nextSessionNote    String?   // LEGACY (project-wide)
  lastSessionSummary String?   @db.Text // LEGACY — resumen manual de la última sesión (el widget ya no lo edita)
  pendingItems       Json?     // Array de { text: string, done: boolean }

  // Override manual de la PRÓXIMA sesión POR FRENTE — para reuniones "ajenas a meets"
  // (no capturadas por el sync de Google Workspace). El widget GPS muestra dos frentes
  // (Ventas / CS); si hay override manual para un frente, precede al auto-detectado.
  salesNextSessionDate DateTime? // Próxima sesión de VENTAS agendada a mano
  salesNextSessionNote String?   // Nota de la próxima sesión de ventas
  csNextSessionDate    DateTime? // Próxima sesión de CS (entrega de servicio) agendada a mano
  csNextSessionNote    String?   // Nota de la próxima sesión de CS

  // Fase C — publish del Kickoff al cliente externo. Acción SEPARADA del acceso:
  // null = no publicado (el cliente, aunque tenga credenciales, no ve el Kickoff);
  // fecha = publicado. El chokepoint externo (lib/external/kickoff-view.ts) exige
  // que esto NO sea null en CADA lectura, así despublicar corta el acceso al instante.
  kickoffPublishedAt DateTime?

  // D.1.5 — publish del CRONOGRAMA al cliente externo. Regla UNIFICADA: gobierna
  // el cronograma donde sea que aparezca (página /external/cronograma Y la sección
  // embebida en el kickoff). Independiente de kickoffPublishedAt — una superficie
  // puede estar publicada sin la otra. Chequeado en CADA lectura por los chokepoints.
  timelinePublishedAt DateTime?

  // #3 — visibilidad de secciones/procesos en el kickoff del cliente, por proyecto.
  // hiddenKickoffKeys = claves OCULTAS del kickoff. Una clave puede ser:
  //   · el id de una CanvasSection del kickoff → oculta esa sección de contenido,
  //   · "cronograma" → oculta la sección de cronograma embebida (independiente del
  //      publish del cronograma standalone, timelinePublishedAt),
  //   · "procesos" → oculta toda la sección de procesos,
  //   · el id de un flowchart de proceso → oculta ESE proceso.
  // El chokepoint (lib/external/kickoff-view.ts) filtra por este set. Reversible, no borra datos.
  hiddenKickoffKeys String[] @default([])
  // Legacy — reemplazado por hiddenKickoffKeys (se mantiene la columna por compat; sin uso en código).
  procesosHiddenFromKickoff Boolean @default(false)

  // Propiedades sincronizadas desde HubSpot (objeto Service)
  hubspotOwnerId      String?   // hubspot_owner_id (ID del owner en HubSpot)
  hubspotOwnerName    String?   // Nombre del owner (CSE encargado) resuelto desde /owners/{id}
  hubspotOwnerEmail   String?   // Email del owner
  hubspotCreatedAt    DateTime? // hs_createdate del servicio en HubSpot
  hubspotPipelineName String?   // Nombre del pipeline resuelto desde hs_pipeline

  // D.2 — etapa actual del pipeline de Customer Success (híbrido: materializada acá
  // por sync-projects y revalidada en vivo al disparar la regeneración del cronograma).
  // El label es lo que el agente de avance razona (ancla #1); el id permite comparar.
  hubspotPipelineStageLabel String?   // label legible de hs_pipeline_stage (p.ej. "Onboarding")
  hubspotPipelineStageId    String?   // id de la etapa (hs_pipeline_stage) para comparar/revalidar
  hubspotStageSyncedAt      DateTime? // última vez que se materializó/revalidó la etapa

  // D.3 panel — SALUD del proyecto, HÍBRIDA: el panel de cartera PROPONE una salud derivada
  // de señales (atrasos/inactividad/firmeza) calculada al vuelo en lib/portfolio; este override
  // es la versión CURADA por CSL/Ventas/SA. Si hay override prevalece; null = se usa la derivada.
  healthStatusOverride       ProjectHealth?
  healthStatusOverrideReason String?        // por qué el humano fijó este estado
  healthStatusOverrideAt     DateTime?      // cuándo
  healthStatusOverrideBy     String?        // email de quien lo fijó (del guard)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stageNotes   StageNote[]
  contextCards ClientContextCard[]
  documents    ClientDocument[]
  agentRuns    AgentRun[]
  canvases     ProjectCanvas[]
  actionItems  ActionItem[]
  sessions     SessionProject[]
  participantSnapshot ProjectParticipantSnapshot?
  externalAccess      ProjectExternalAccess?
  timeline            ProjectTimeline?
  handoff             Handoff?
  handoffSources      HandoffSource[]
}

// D.3 panel — salud del proyecto para el panel de cartera. Es el OVERRIDE curado; la salud
// derivada (automática) se calcula al vuelo en lib/portfolio a partir de las señales de riesgo.
// PAUSADO espeja el caso Project.status="paused".
enum ProjectHealth {
  SALUDABLE
  EN_FRICCION
  EN_RIESGO
  PAUSADO
}

// ─── Handoff (entidad cliente-level) ──────────────────────────────────────────
// Un handoff nace cuando se gana un deal: lleva la info de ventas a CS y arranca el
// proyecto. 1:N bajo el Client (un cliente acumula varios en el tiempo), 1:1 con un
// Project y con el deal ancla. Su CONTENIDO vive en el canvas "Handoff" del Project
// (1:1) — no se duplica acá. El sync a HubSpot (crear el record "projects" + propiedad
// en la company) es aparte y eventual; lo gobierna hubspotSyncStatus.
model Handoff {
  id            String  @id @default(cuid())
  clientId      String
  client        Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId     String  @unique // 1:1 con el Project (su contenido = canvas "Handoff" del project)
  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  hubspotDealId String? @unique // deal ancla de HubSpot (1 handoff por deal)

  // Sync a HubSpot (eventual + reintentable; ver decisión #2 del plan)
  hubspotProjectId  String? // id del record "projects" creado en HubSpot (post-sync)
  hubspotSyncStatus String  @default("pending") // pending | synced | failed
  hubspotSyncError  String? @db.Text
  // Owner de HubSpot a setear en el record "projects" SOLO cuando el sync lo CREA de
  // cero (handoff nacido del stepper de ventas). null = sin owner forzado (handoffs
  // viejos / generados in-project). Se aplica una sola vez, en CASO B del sync.
  hubspotOwnerIdOnCreate String?

  generatedByAgentRunId String? // trazabilidad de la corrida del agente de handoff

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

// ─── HandoffSource — fuente MANUAL del handoff (transcript/resumen pegado a mano) ──
// Para reuniones que NO entraron por el sync de Google Workspace (ej. un Zoom ajeno):
// ventas pega el transcript/resumen y el agente de handoff lo usa como UNA fuente más,
// ETIQUETADA como manual (distinta de las sesiones verificadas del sync). Keyed por
// projectId (el handoff es 1:1 con el project; persiste aunque el Handoff aún no exista
// o se recree → reproducible/auditable). El analyze la re-lee en CADA corrida, así una
// regeneración la vuelve a incluir. SOLO la lee el path de handoff; NO se muestra en el
// tab Documentos ni alimenta a otros agentes.
model HandoffSource {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String?                          // etiqueta opcional para identificarla
  content        String    @db.Text               // el texto pegado (transcript/resumen)
  kind           String    @default("manual")     // futuro-proof: otros tipos de fuente manual
  createdByEmail String?                           // quién la pegó (del guard de sesión)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?                         // soft-delete (auditable; el read filtra deletedAt:null)

  @@index([projectId, createdAt])
}

// ─── ProjectTimeline + TimelinePhase ──────────────────────────────────────────
// Cronograma estructurado del proyecto (Fase 2 del módulo externo).
//
// Lo propone el agente "Handoff Sales→CS" a partir de las transcripciones de
// ventas (donde típicamente se acuerda la secuencia: "kick-off + arquitectura
// + 6 sesiones de set up + 6 de onboarding, 10 semanas total"). El CSE lo
// edita libremente. Las fases tienen duración en SEMANAS, sin fechas concretas
// — el `anchorStartDate` (opcional) es el ancla; las fechas reales del landing
// se calculan en runtime como `anchorStartDate + sum(durationWeeks_anteriores) * 7 días`.
//
// Patrón de re-ejecución: el agente solo crea el cronograma si NO existe. Si
// ya hay uno, la nueva propuesta queda en AgentRun.output (trazabilidad) pero
// no se aplica — para regenerar, el CSE borra explícitamente y vuelve a correr.

model ProjectTimeline {
  id                    String          @id @default(cuid())
  projectId             String          @unique
  project               Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  anchorStartDate       DateTime?       // null hasta que el CSE la fije; cuando exista, define la conversión semanas → fechas
  lastEditedByHuman     DateTime?       // se actualiza en cada PUT que toca fases (no en el create del agente)
  // D.3 staging — el cliente ve SOLO este SNAPSHOT (shape client-safe de readClientTimeline)
  // congelado al "Subir". La vista externa NUNCA lee en vivo: si está publicado y el snapshot
  // es null (timeline pre-D.3), readPublishedClientTimeline hace un backfill perezoso (congela
  // el vivo actual una vez); si no hay timeline, devuelve vacío (fail-closed).
  publishedSnapshot     Json?
  generatedByAgentRunId String?         // de qué AgentRun salió la propuesta inicial (trazabilidad)
  generatedByAgentRun   AgentRun?       @relation(fields: [generatedByAgentRunId], references: [id], onDelete: SetNull)
  // D.1 — cronograma detallado:
  detailConfirmedAt           DateTime? // gate de la vista cliente: las tareas solo cruzan al kickoff externo si != null
  detailGeneratedByAgentRunId String?   // de qué AgentRun salió el detalle (tareas/tipos) — trazabilidad
  detailGeneratedByAgentRun   AgentRun? @relation("TimelineDetailGenerator", fields: [detailGeneratedByAgentRunId], references: [id], onDelete: SetNull)
  // Re-generación en proyectos en curso: cuando el agente re-deriva un cronograma y YA existe uno,
  // la propuesta NO se aplica (protege ediciones/progreso) — se guarda acá, reconciliada al shape del
  // PUT (fases con id existente cuando matchean, SIN `tasks` para preservar el detalle), y el canvas
  // la muestra como vista previa aplicable. null = sin propuesta pendiente. Se limpia al aplicar/descartar.
  pendingProposal       Json?
  pendingProposalRunId  String?         // AgentRun del que salió la propuesta pendiente (trazabilidad)
  // D.2 — BORRADOR DE AVANCE (hermano de pendingProposal; NO se mezcla). El agente de
  // avance detecta qué fases/tareas están hechas y dónde cae el "hoy", y lo guarda acá
  // SIN tocar status (eso lo confirma el CSE). Shape: { currentPhaseId, asOfSessionId,
  // reasoning, phases:[{id,done}], tasks:[{id,done}] }. Se reemplaza en cada corrida;
  // se limpia al aplicar (timeline/progress/apply) o descartar (DELETE timeline/progress).
  pendingProgress       Json?
  pendingProgressRunId  String?         // AgentRun del que salió el borrador de avance (trazabilidad)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  phases                TimelinePhase[]
  changes               TimelineChange[] // #4 — historial de ediciones (razón + snapshot) para D.3
  baselines             TimelineBaseline[] // D.3 — baselines "vendidos" congelados al publicar (versionados)

  @@index([projectId])
}

model TimelinePhase {
  id            String                @id @default(cuid())
  timelineId    String
  timeline      ProjectTimeline       @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  name          String                                  // "Kick-off", "Arquitectura", etc.
  order         Int                                     // 0-indexed, posición en la secuencia
  durationWeeks Int                   @default(1)       // 1+
  // Inicio EXPLÍCITO (offset 0-based desde anchorStartDate). null = contigua tras la fase anterior
  // (comportamiento por defecto). Habilita fases EN PARALELO (dos con el mismo inicio se solapan):
  // típico, una integración/desarrollo que corre en paralelo a la implementación del hub.
  startWeek     Int?
  sessionCount  Int?                                    // opcional — algunas fases no son por sesiones
  notes         String?               @db.Text          // texto libre opcional (contexto editable)
  activityType  TimelineActivityType?                   // D.1: tipo de actividad (nullable — fases pre-D.1 quedan sin tipo, render neutro)
  source        TimelinePhaseSource   @default(AGENT)
  // El agente del handoff marca true cuando ESTIMÓ la fase/duración sin dato real en ventas
  // (badge "estimada" + banner). Se limpia cuando el CSE edita la fase (PUT). Interno — NO cruza al cliente.
  needsValidation Boolean             @default(false)
  // D.2 — avance a nivel fase (reusa el enum de tarea). DONE = fase completada;
  // IN_PROGRESS = la fase en curso (el "hoy"); PENDING = por delante. Lo escribe SOLO
  // el CSE (mismo invariante que TimelineTask.status); el agente lo PROPONE en pendingProgress.
  status        TimelineTaskStatus    @default(PENDING)
  // D.3 fundación — fechas REALES de ejecución, MONÓTONAS (no se auto-borran):
  // actualStart la 1ra vez que va a IN_PROGRESS/DONE; actualEnd al DONE. Volver a
  // PENDING/IN_PROGRESS NO las borra — el status manda para "¿hecho hoy?", las fechas son histórico.
  actualStart   DateTime?
  actualEnd     DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  tasks         TimelineTask[]

  @@index([timelineId, order])
}

// D.1 — tarea de una fase del cronograma. weekIndex es RELATIVO a la fase
// (0-indexed, rango [0, durationWeeks)); en UI se muestra 1-based.
// El estado vive separado del contenido a propósito: D.2 podrá regenerar
// contenido preservando estados humanos por id. Invariante D.1: el agente
// solo crea PENDING → todo status != PENDING es humano por definición.
model TimelineTask {
  id              String              @id @default(cuid())
  phaseId         String
  phase           TimelinePhase       @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  title           String
  weekIndex       Int                                   // 0-indexed, relativo a la fase
  order           Int                 @default(0)       // orden dentro de la semana
  status          TimelineTaskStatus  @default(PENDING)
  // #4 — override manual de fechas por tarea. INTENCIÓN: cuando estén seteadas deben
  // ganar sobre la fecha DERIVADA de la semana (anchor + offset de fase + weekIndex) y
  // cruzar al cronograma compartible como fecha efectiva. Se editan con datepicker en el
  // drawer (chip "manual"). ESTADO: se PERSISTEN, pero el consumo en el render (Gantt
  // interno + vista externa) está PENDIENTE — hoy ningún render prefiere el override sobre
  // la fecha derivada. null = derivar (default).
  startDateOverride DateTime?
  dueDateOverride   DateTime?
  // D.3 fundación — fechas REALES de ejecución (ver TimelinePhase).
  actualStart     DateTime?
  actualEnd       DateTime?
  notes           String?             @db.Text
  needsValidation Boolean             @default(false)   // tarea típica inventada por el agente con handoff flaco — el Gantt la grita; NUNCA cruza al cliente
  // B — dueño de la tarea en el plan de alineación compartido. CLIENTE entrega/hace;
  // SMARTEAM configura; AMBOS trabajo conjunto. Nullable = sin asignar (data pre-B).
  // Cruza al cronograma compartible del cliente (gated por "Subir"); el Kickoff embebido NO lo muestra.
  party           TaskParty?
  // ¿la tarea es una SESIÓN (reunión con el cliente) o una TASK (acción/entregable)?
  // Nullable = sin tipar (efectivo = TASK). Cruza al cronograma compartible SOLO si es SESSION.
  // Mapeo a futuro (NO se sincroniza hoy): SESSION → HubSpot Meeting (0-47); TASK → HubSpot Task (0-27).
  type            TimelineTaskType?
  source          TimelinePhaseSource @default(AGENT)   // reuso consciente del enum (mismo ciclo AGENT→MODIFIED/HUMAN); renombrarlo = recrear tipo en PG por cero ganancia
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([phaseId, weekIndex, order])
}

enum TimelinePhaseSource {
  AGENT      // generada por la IA, sin tocar humano
  MODIFIED   // generada por IA, editada por humano (al pasar por PUT con id existente)
  HUMAN      // creada desde cero por humano (PUT con phase sin id)
}

// B — dueño de una tarea del cronograma, desde la óptica del plan compartido con el cliente.
enum TaskParty {
  CLIENTE   // lo entrega o hace el cliente (insumos: documentación, bases, listados, accesos)
  SMARTEAM  // configuración técnica en HubSpot (pipeline, propiedades, automatizaciones, integraciones)
  AMBOS     // trabajo conjunto (sesiones, talleres, validaciones, onboarding, seguimiento)
  DEV       // #7 — desarrollo/integración (equipo técnico). Tareas de la fase "Desarrollo / Integración".
}

// Tipo de tarea del cronograma. Mapea a futuro (sin sync hoy):
// SESSION → HubSpot Meeting (objeto 0-47); TASK → HubSpot Task (objeto 0-27, hs_task_type=TODO).
enum TimelineTaskType {
  SESSION   // reunión / sesión de trabajo con el cliente (kickoff, revisión, demo, capacitación)
  TASK      // acción / entregable / configuración (no es una reunión)
}

// #4 — historial de cambios del cronograma. Cada edición lleva una razón OBLIGATORIA
// y guarda un snapshot del estado resultante (no es un log efímero) para que D.3 pueda
// comparar el cronograma "vendido" (primer snapshot) contra el "real" (último) y
// explicar los desvíos con su motivo.
model TimelineChange {
  id             String             @id @default(cuid())
  timelineId     String
  timeline       ProjectTimeline    @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  reason         String             @db.Text          // obligatoria — el "por qué" del cambio
  kind           TimelineChangeKind @default(MANUAL)
  instruction    String?            @db.Text          // si kind=AI_ASSIST, la instrucción dada al asistente
  changedByEmail String?                              // quién hizo el cambio (del guard de sesión)
  snapshot       Json                                 // estado resultante: { anchorStartDate, phases:[{...,tasks:[...]}] }
  createdAt      DateTime           @default(now())

  @@index([timelineId, createdAt])
}

enum TimelineChangeKind {
  MANUAL     // edición manual del CSE ("Guardar cronograma")
  AI_ASSIST  // aplicada desde una propuesta del asistente de IA
  PROGRESS   // D.3 — confirmación de avance (D.2): registra qué se marcó y quién (delta compacto, sin snapshot completo)
}

// D.3 fundación — BASELINE "vendido" congelado al PUBLICAR el cronograma al cliente.
// Snapshot prístino e independiente de si el CSE editó a mano: es la promesa contra la
// que D.3 (después) compara lo ejecutado. Versionado: cada publish con estructura distinta
// crea una versión nueva (isActive=true) y desactiva la anterior — se conservan todas.
// El snapshot incluye fechas planeadas por ítem + needsValidation + source para que las
// alarmas distingan "te desviaste de algo firme" de "de un relleno del agente".
model TimelineBaseline {
  id               String          @id @default(cuid())
  timelineId       String
  timeline         ProjectTimeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  version          Int                              // 1, 2, 3… (max+1 por timeline)
  isActive         Boolean         @default(true)   // la última publicada; D.3 compara contra esta
  anchorStartDate  DateTime?                        // ancla al momento de congelar
  snapshot         Json                             // estructura frozen: fases+tareas con planned dates, needsValidation, source
  firmness         Json                             // resumen de firmeza: { taskCount, needsValidationCount, firmPct, label, ... }
  publishedByEmail String?                          // quién publicó (del guard)
  capturedAt       DateTime        @default(now())

  @@index([timelineId, isActive])
  @@index([timelineId, version])
}

// D.1 — los 5 tipos de actividad de una implementación (orden de negocio fijo).
// Mapean a colores/leyenda en el Gantt interno; el cliente no los ve.
enum TimelineActivityType {
  EXPLORACION
  PLANIFICACION
  CONFIGURACION
  ADOPCION
  SEGUIMIENTO
}

enum TimelineTaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  SUSPENDED // E — tarea aparcada/descartada: resuelta (no pendiente ni vencida), no se ejecutó
}

// ─── ProjectExternalAccess ────────────────────────────────────────────────────
// Mecanismo de acceso del cliente externo al landing de SU proyecto.
// Combinación token (URL) + contraseña hasheada (form). Necesita ambos.
// 1:1 con Project. El CSE genera/regenera/revoca desde el panel del proyecto.
// La contraseña se devuelve EN PLANO una sola vez al generarla; después solo
// queda el hash (bcrypt 12 rounds). Si se pierde, hay que regenerar.
// Coexiste con Project.shareToken (vista pública sin contraseña, feature aparte).

model ProjectExternalAccess {
  id            String    @id @default(cuid())
  projectId     String    @unique
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  accessToken   String    @unique           // 64 chars hex (crypto.randomBytes(32))
  passwordHash  String                       // bcrypt(12 rounds) — lo usa verify-access
  accessPassword String?                     // texto plano (visible para el CSE en el panel; igual se entrega al cliente en claro). Null en accesos viejos pre-migración.
  enabledAt     DateTime  @default(now())
  revokedAt     DateTime?                    // si != null → acceso bloqueado
  lastUsedAt    DateTime?                    // se actualiza en cada verify OK
  createdById   String?                      // FK a TeamMember que generó el acceso (auditoría)
  createdBy     TeamMember? @relation("ExternalAccessCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([accessToken])
  @@index([projectId])
}

// Canvas dentro de un proyecto (default = "Canvas de servicio", custom = secciones libres)
model ProjectCanvas {
  id        String   @id @default(cuid())
  // Dueño flexible: el canvas cuelga de un Project (kickoff/diagnóstico/…) O de un
  // BusinessCase (Ventas). Exactamente uno seteado (validado en código).
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  businessCaseId String?
  businessCase   BusinessCase? @relation(fields: [businessCaseId], references: [id], onDelete: Cascade)
  name      String
  isDefault Boolean  @default(false)
  order     Int      @default(0) // orden de aparición en el dropdown de canvases
  // Versionado (business case): cada "Generar" crea un canvas nuevo; isActive marca
  // el vivo/editable. En proyectos queda version=1/isActive=true (sin uso).
  version   Int      @default(1)
  isActive  Boolean  @default(true)
  sections  Json     @default("[]") // Array de { key, label, brief?, previousBrief? } — brief = guía del agente por sección (BC), acá y no en columna para sobrevivir db push entre las 2 PCs (ver lib/business-cases/section-briefs.ts)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // D.3 staging — el cliente ve el SNAPSHOT publicado; el contenido vivo es borrador hasta "Subir".
  // publishedSnapshot = foto client-safe al subir; contentUpdatedAt se toca al editar/confirmar bloques
  // (dispara "cambios sin subir" si contentUpdatedAt > publishedSnapshotAt).
  publishedSnapshot   Json?
  publishedSnapshotAt DateTime?
  contentUpdatedAt    DateTime?

  cards           ClientContextCard[]
  canvasSections  CanvasSection[]

  @@index([projectId])
  @@index([businessCaseId])
}

// Sección de un canvas no-default (entidad de primer nivel)
model CanvasSection {
  id        String   @id @default(cuid())
  canvasId  String
  canvas    ProjectCanvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  key       String
  label     String
  titleOverride String? // Título de cara al cliente editado por el CSE (landing Kickoff). null = título por defecto de la plantilla (SECTION_META).
  eyebrowOverride String? // Eyebrow (título pequeño) editado por el CSE. null = eyebrow por defecto de la plantilla.
  // NOTA: la "guía del agente" por sección (business case) NO vive acá. Se guarda en
  // ProjectCanvas.sections (Json) para sobrevivir db push entre las 2 PCs que comparten
  // la DB de prod. Ver lib/business-cases/section-briefs.ts.
  // Deshacer de 1 nivel (persistido): valor inmediatamente anterior de title/eyebrow. null = nada que deshacer.
  previousTitleOverride   String?
  previousEyebrowOverride String?
  order     Int      @default(0)
  layout    Json?    // RGL layout: [{ i: blockId, x, y, w, h }]
  createdAt DateTime @default(now())

  blocks    CanvasBlock[]

  @@unique([canvasId, key])
  @@index([canvasId])
}

// Bloque de contenido dentro de una sección (text, heading, table, metric, callout, etc.)
model CanvasBlock {
  id         String      @id @default(cuid())
  sectionId  String
  section    CanvasSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  blockType  BlockType   @default(TEXT)
  content    String?     @db.Text
  data       Json?
  // Deshacer de 1 nivel (persistido): contenido/data inmediatamente anterior. null = nada que deshacer.
  previousContent String? @db.Text
  previousData    Json?
  order      Int         @default(0)
  colSpan    Int         @default(4) // 1-4 columns width
  colStart   Int?        // 1-4 column start position (null = auto)
  rowSpan    Int         @default(4) // height in grid rows
  source     BlockSource @default(AGENT)
  status     BlockStatus @default(DRAFT)
  agentRunId String?
  agentRun   AgentRun?   @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  createdAt  DateTime    @default(now())

  @@index([sectionId])
  @@index([agentRunId])
}

// Notas/contenido guardadas por etapa y paso dentro del workspace de un cliente
model StageNote {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage     Int      // 1 = Diagnóstico | 2 = MVP | 3 = Adopción
  step      Int      // número de paso dentro de la etapa (1-indexed)
  content   String   @db.Text @default("")

  updatedAt DateTime @updatedAt

  @@unique([clientId, stage, step])
}

// Documentos adjuntos al workspace de un cliente (transcripciones, briefs, URLs, etc.)
model ClientDocument {
  id        String       @id @default(cuid())
  clientId  String
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage     Int?         // null = global (tab Documentos), 1 o 2 o 3 = etapa específica
  step      Int?         // paso específico (opcional)
  title     String
  type      DocumentType
  content   String?      @db.Text // para FREE_TEXT / CALL_TRANSCRIPT pegado / texto extraído de FILE
  url       String?               // para URL, Fireflies links, o Supabase Storage URL
  fileName  String?               // nombre original del archivo (para FILE)
  fileSize  Int?                  // tamaño en bytes (para FILE)
  mimeType  String?               // tipo MIME (para FILE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Cards de contexto del cliente (sección editable sobre la relación comercial, dolor, etc.)
model ClientContextCard {
  id         String    @id @default(cuid())
  clientId   String
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId  String?
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // null = card manual/legacy; set = generada por un AgentRun específico
  agentRunId String?
  agentRun   AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  title      String
  content    String    @db.Text @default("")
  order      Int       @default(0)
  source     CardSource @default(HUMAN)
  cardType   CardType   @default(TEXT)

  // Canvas integration
  canvasId      String?  // null = canvas default del proyecto
  canvas        ProjectCanvas? @relation(fields: [canvasId], references: [id], onDelete: SetNull)
  canvasSection String?  // Sección del canvas donde vive (null = no está en canvas)
  canvasOrder   Int?     // Orden dentro de la sección del canvas (para drag & drop)
  canvasStatus  String   @default("confirmed") // "draft" = auto-poblado por agente, pendiente de revisión; "confirmed" = aceptado por CSE

  // Card hierarchy (para clones al enviar al canvas)
  parentCardId  String?
  parentCard    ClientContextCard?  @relation("CardClones", fields: [parentCardId], references: [id], onDelete: SetNull)
  clones        ClientContextCard[] @relation("CardClones")

  // Datos estructurados por tipo
  diagramData   Json?    // Para FLOWCHART: { nodes: [...], edges: [...] }
  chartConfig   Json?    // Para CHART: configuración de ECharts

  // Vista del cliente
  publishedToClient Boolean @default(false) // Si true, visible en la vista externa del cliente
  publishedContent  String? @db.Text        // Versión alternativa del contenido para el cliente (lenguaje suavizado)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Cards de un mismo run no pueden tener el mismo título
  @@unique([agentRunId, title])
  @@index([clientId, agentRunId])
  @@index([agentRunId])
  @@index([canvasId])
  @@index([canvasSection])
  @@index([parentCardId])
}

// ─── HubspotAccount (ahora hijo de Client) ───────────────────────────────────

model HubspotAccount {
  id              String   @id @default(cuid())
  isSystem        Boolean  @default(false) // true = cuenta del sistema (Smarteam), false = cuenta de cliente
  clientId        String?  @unique // nullable en transición — se hará NOT NULL en Fase 5
  client          Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  hubspotPortalId String   @unique
  hubName         String?
  accessToken     String
  refreshToken    String
  expiresAt       DateTime
  portalSnapshot   Json?
  portalSnapshotAt DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relaciones legacy (se eliminan en Fase 5 una vez migrada toda la data)
  implementations Implementation[]
  audits          Audit[]
  knowledge       Knowledge[]
}

// ─── Knowledge ────────────────────────────────────────────────────────────────

model Knowledge {
  id        String         @id @default(cuid())
  accountId String
  account   HubspotAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  clientId  String?        // se poblará en migración de datos (Fase 5)
  client    Client?        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title     String
  content   String         @db.Text
  category  String         @default("general")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// ─── Audit ────────────────────────────────────────────────────────────────────

model Audit {
  id        String         @id @default(cuid())
  accountId String?        // nullable en transición (Fase 3 lo migra a clientId)
  account   HubspotAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  clientId  String?        // nuevo FK a Client (se poblará en Fase 3)
  client    Client?        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  data      Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// ─── Implementation ───────────────────────────────────────────────────────────

model Implementation {
  id        String               @id @default(cuid())
  accountId String?              // nullable en transición (Fase 4 lo migra a clientId)
  account   HubspotAccount?      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  clientId  String?              // nuevo FK a Client (se poblará en Fase 4)
  client    Client?              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  status    ImplementationStatus @default(PLANNING)
  archived  Boolean              @default(false)
  plan      Json?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  messages   Message[]
  executions ExecutionLog[]
}

// ─── Message ──────────────────────────────────────────────────────────────────

model Message {
  id               String         @id @default(cuid())
  implementationId String
  implementation   Implementation @relation(fields: [implementationId], references: [id], onDelete: Cascade)
  role             String
  content          String         @db.Text
  createdAt        DateTime       @default(now())
}

// ─── Agent ────────────────────────────────────────────────────────────────────

model Agent {
  id                     String          @id @default(cuid())
  name                   String
  description            String?
  systemPrompt           String          @db.Text
  additionalInstructions String?         @db.Text
  status                 AgentStatus     @default(DRAFT)
  // Etapas asociadas: [] = aplica a todas, [1] = solo Etapa 1, [1,2] = ambas
  associatedStages       Int[]
  associatedStep         Int?
  sectionLabel           String?         // Bloque visual dentro de la subetapa (ej. "Contexto del cliente")
  outputType             AgentOutputType @default(CARDS)
  scope                  AgentScope      @default(CLIENT)
  agentType              AgentType       @default(SECTION)
  defaultCanvasSection   String?         // Sección del canvas de proyecto sugerida al enviar cards (ej. "procesos")
  // Agrupación por propósito (reemplaza stages/steps para la UI)
  agentGroup             String?         // handoff | preparacion | diagnostico | planificacion | ejecucion | adopcion (ver lib/agent-groups.ts)
  groupOrder             Int             @default(0) // Orden DENTRO de su grupo (no del grupo). Para chaining: agentes con groupOrder menor se inyectan como contexto a los mayores del mismo grupo.
  // IDs de KnowledgeDocument inyectados sin truncar al prompt del agente (referencia principal)
  pinnedKnowledgeIds     String[]        @default([])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  runs AgentRun[]

  @@index([associatedStep])
}

model AgentRun {
  id          String         @id @default(cuid())
  agentId     String?
  agent       Agent?         @relation(fields: [agentId], references: [id], onDelete: SetNull)
  clientId    String
  client      Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  businessCaseId String?
  businessCase   BusinessCase? @relation(fields: [businessCaseId], references: [id], onDelete: Cascade)
  stage       Int?
  step        Int?
  stepLabel    String?        // nombre legible de la subetapa (ej. "Análisis inicial")
  sectionLabel String?        // sección dentro de la subetapa (ej. "Contexto del cliente")
  serviceType  String?        // tipo de servicio al momento de la ejecución
  status      AgentRunStatus @default(PENDING)
  output      String?        @db.Text // JSON raw de Claude (backup)

  // ── Análisis contextuales desde /sessions (Fase 9) ──────────────────────────
  sourceSessionIds String[] @default([])         // ids de FirefliesSession usados como input
  filters          Json?                         // snapshot de filtros: { from, to, teamRoles[], onlyWithContent }
  agentSlug        String?                       // identificador estable: "sales-analysis" | "service-analysis"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cards                    ClientContextCard[]
  blocks                   CanvasBlock[]
  generatedTimelines       ProjectTimeline[]
  detailGeneratedTimelines ProjectTimeline[] @relation("TimelineDetailGenerator")

  @@index([status])
  @@index([clientId, agentSlug, createdAt])
}

// ─── Business Cases (Ventas) — generador de casos de negocio ─────────────────
// Entidad 1:N bajo Client (NO bajo Project). Flujo: generar (agente) →
// editar/confirmar (vendedor) → publicar (snapshot congelado + acceso
// token+password, mismo patrón que ProjectExternalAccess).

model BusinessCase {
  id               String             @id @default(cuid())
  clientId         String
  client           Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  hubspotCompanyId String?            // empresa de HubSpot asociada al caso
  hubspotDealId    String?            // deal de HubSpot (opcional)
  name             String
  slug             String             @unique // referencia interna (URLs de admin)
  status           BusinessCaseStatus @default(DRAFT)

  // Clasificación (tira de tags) — MISMO catálogo y modalidad que Project (lib/tags/catalog.ts).
  // El agente del BC los detecta; el CSE corrige. Se PROPAGAN al Project al crear el handoff
  // (match por hubspotDealId). tags = slugs de product+scope; implementationType = modalidad.
  tags               String[]            @default([])
  implementationType ImplementationType?

  // Tipo de caso (slug del catálogo TS en lib/business-cases/case-types.ts) — determina
  // template de landing + tags seed. String? y NO enum (agregar tipos sin migración;
  // valor desconocido degrada al default). null = implementación HubSpot (legacy/default).
  // Respaldo dual-PC: la entry `__meta` del Json sections del canvas v0 (template-meta.ts).
  caseType    String?
  caseSubtype String? // sub-tipo (website: "ecommerce" | "informativo")

  // D.3 staging — el prospecto ve el SNAPSHOT publicado; el contenido vivo es
  // borrador hasta "Publicar". publishedSnapshot = foto client-safe de bloques.
  publishedAt       DateTime?
  publishedSnapshot Json?

  createdByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  blocks      BusinessCaseBlock[]          // (v1 — se elimina en la limpieza F7)
  canvases    ProjectCanvas[]              // canvases versionados (cada "Generar" = uno nuevo)
  sessions    BusinessCaseSession[]        // sesiones de contexto incluidas/excluidas
  transcripts BusinessCaseTranscript[]
  useCases    BusinessCaseUseCase[]        // checklist del catálogo de casos de uso
  access      BusinessCaseExternalAccess?
  agentRuns   AgentRun[]

  @@index([clientId])
}

// ─── Catálogo de casos de uso (Ventas) ────────────────────────────────────────
// Checklist INTERNO del vendedor: casos de uso pre-armados con precio que se marcan
// por BC y se materializan determinísticamente en la sección `casos_de_uso` (el
// agente NUNCA los genera → precios exactos). 100% opcional: sin filas aplicables,
// el flujo de texto libre sigue idéntico. Tabla propia (NO KnowledgeDocument: los
// docs PUBLISHED se inyectan al contexto de OTROS agentes y esto lleva precios).
model UseCase {
  id             String   @id @default(cuid())
  title          String
  description    String   @db.Text // markdown corto (checklist + landing)
  price          String?  // TEXTO libre mostrable ("USD 1.200", "desde $X/mes") — NUNCA numérico (sin calculadora, por diseño)
  appliesTo      String[] @default([]) // slugs de caseType (case-types.ts); [] = aplica a TODOS los tipos
  tags           String[] @default([]) // slugs del catálogo lib/tags (mismo vocabulario que BusinessCase.tags)
  active         Boolean  @default(true)
  order          Int      @default(0)
  createdByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  businessCases BusinessCaseUseCase[]

  @@index([active])
}

// Pivote BC ↔ caso de uso — espejo de BusinessCaseSession. SEMÁNTICA: sin fila = no
// seleccionado; la fila se crea recién al primer toggle (un seed que cree filas para
// todos los candidatos invertiría el default). La verdad PUBLICABLE es el `data` de
// la sección `casos_de_uso` del canvas; el pivote es estado de trabajo + input del prompt.
model BusinessCaseUseCase {
  id             String       @id @default(cuid())
  businessCaseId String
  businessCase   BusinessCase @relation(fields: [businessCaseId], references: [id], onDelete: Cascade)
  useCaseId      String
  useCase        UseCase      @relation(fields: [useCaseId], references: [id], onDelete: Cascade)
  selected       Boolean      @default(true)
  priceOverride  String?      // precio negociado para ESTE caso (texto)
  createdAt      DateTime     @default(now())

  @@unique([businessCaseId, useCaseId])
  @@index([businessCaseId])
}

model BusinessCaseSession {
  id             String       @id @default(cuid())
  businessCaseId String
  businessCase   BusinessCase @relation(fields: [businessCaseId], references: [id], onDelete: Cascade)
  sessionId      String       // FirefliesSession.id (sin FK dura: la sesión puede no existir aún)
  included       Boolean      @default(true) // el vendedor incluye/excluye del contexto de generación
  createdAt      DateTime     @default(now())

  @@unique([businessCaseId, sessionId])
  @@index([businessCaseId])
}

model BusinessCaseBlock {
  id              String                @id @default(cuid())
  businessCaseId  String
  businessCase    BusinessCase          @relation(fields: [businessCaseId], references: [id], onDelete: Cascade)
  blockType       BusinessCaseBlockType
  order           Int                   @default(0)
  content         Json                  // estructurado por blockType (ver lib/business-cases/schema.ts)
  previousContent Json?                 // deshacer de 1 nivel
  status          BlockStatus           @default(DRAFT)
  source          BlockSource           @default(AGENT)
  isVisible       Boolean               @default(true)
  needsValidation Boolean               @default(false) // el agente no tuvo contexto suficiente
  confirmedAt     DateTime?
  confirmedByEmail String?
  agentRunId      String?               // provenance (sin FK dura)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([businessCaseId])
}

model BusinessCaseTranscript {
  id             String                       @id @default(cuid())
  businessCaseId String
  businessCase   BusinessCase                 @relation(fields: [businessCaseId], references: [id], onDelete: Cascade)
  source         BusinessCaseTranscriptSource
  rawText        String                       @db.Text // pegado, o texto extraído del archivo
  fileName       String?
  fileUrl        String?                      // path en Supabase Storage (UPLOADED)
  fileSize       Int?
  mimeType       String?
  processedAt    DateTime?
  createdAt      DateTime                     @default(now())

  @@index([businessCaseId])
}

model BusinessCaseExternalAccess {
  id             String       @id @default(cuid())
  businessCaseId String       @unique
  businessCase   BusinessCase @relation(fields: [businessCaseId], references: [id], onDelete: Cascade)
  accessToken    String       @unique // 64 hex (crypto.randomBytes(32))
  passwordHash   String                // bcrypt(12)
  accessPassword String?               // texto plano para que el vendedor lo comparta
  enabledAt      DateTime     @default(now())
  revokedAt      DateTime?
  lastUsedAt     DateTime?
  createdByEmail String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([accessToken])
  @@index([businessCaseId])
}

// ─── TeamMember ───────────────────────────────────────────────────────────────
// Identidad interna del equipo de Smarteam. El email es la llave que cruza
// con AppUser.email (que a su vez se vincula con auth.users de Supabase Auth).
// El roleEnum reemplaza al string legacyRole; el viejo se mantiene para
// auditoría de migración y se elimina cuando estabilice el roleEnum.

model TeamMember {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  // ÁREA FUNCIONAL — eje de ANÁLISIS de sesiones, NO permisos. Valores: Ventas,
  // CSE, CSL, Marketing, Development, PM, Admin, RevOps (set abierto). Antes se
  // llamaba `role`; se renombró a `area` para no confundir con roleEnum (permisos).
  // Marco Salas, p.ej., es roleEnum=SUPER_ADMIN pero area=Ventas (análisis).
  area                String?
  // ROL DE PERMISO — única fuente de verdad de acceso/capacidades. Ver lib/auth/roles.ts.
  roleEnum            TeamRole  @default(CSE)
  // Visibilidad total HOY se deriva del rol (todos menos CSE ven todo). Este flag
  // queda como override excepcional (ej. un CSE con acceso temporal a todo).
  canViewAllClients   Boolean   @default(false)
  canViewAllExpiresAt DateTime?
  // Baja blanda: si != null, el miembro pierde acceso (login bloqueado) y desaparece
  // de los listados de personas, pero su histórico (sesiones/handoffs/runs) queda intacto.
  deactivatedAt       DateTime?
  deactivatedReason   String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Inversas
  appUser                  AppUser?
  clientAssignments        ClientAssignment[]      @relation("AssignedTo")
  grantedAssignments       ClientAssignment[]      @relation("GrantedBy")
  externalAccessesCreated  ProjectExternalAccess[] @relation("ExternalAccessCreator")
}

enum TeamRole {
  CSE         // scoped: solo sus clientes asignados (owner) + los compartidos
  VENTAS      // ve todo + handoff en cualquiera; NO comparte
  CSL         // ve todo + handoff en cualquiera + comparte; NO gestiona equipo
  MARKETING   // capacidades = CSL (etiqueta distinta para análisis/UI)
  DEV         // equipo técnico: capacidades = VENTAS (ve todo + cronogramas + handoffs) + área Ventas
  SUPER_ADMIN // todo + ÚNICO que gestiona el equipo (alta/baja/cambio de rol)
}

// ─── AppUser ──────────────────────────────────────────────────────────────────
// Identidad unificada que vincula auth.users (Supabase Auth) con el modelo
// de Nexus. Hay dos kinds:
//   - INTERNAL: equipo de Smarteam. teamMemberId set, clientId null.
//   - EXTERNAL: cliente final (onboarding). clientId set, teamMemberId null.
// El authUserId se vincula en el primer login (callback de Google OAuth).

model AppUser {
  id           String      @id @default(cuid())
  authUserId   String?     @unique          // FK suave a auth.users.id de Supabase (null hasta primer login)
  email        String      @unique
  kind         AppUserKind
  teamMemberId String?     @unique
  teamMember   TeamMember? @relation(fields: [teamMemberId], references: [id], onDelete: SetNull)
  clientId     String?
  client       Client?     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([email])
  @@index([authUserId])
}

enum AppUserKind {
  INTERNAL
  EXTERNAL
}

// ─── ClientAssignment ─────────────────────────────────────────────────────────
// Overrides manuales bidireccionales para la asignación CSE↔Cliente, en
// adición al default automático (hubspotOwnerEmail). GRANT da acceso a un
// CSE a un cliente que no es su owner; REVOKE quita acceso a un CSE que sí
// es owner (raro). Solo ADMIN/SUPER_ADMIN puede crearlos (grantedById).

model ClientAssignment {
  id           String         @id @default(cuid())
  clientId     String
  client       Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Target del compartir: a UNA persona (teamMemberId) O a un ROL entero
  // (targetRole, ej. CSE = "todo el equipo CSE"). Exactamente uno de los dos.
  teamMemberId String?
  teamMember   TeamMember?    @relation("AssignedTo", fields: [teamMemberId], references: [id], onDelete: Cascade)
  targetRole   TeamRole?
  kind         AssignmentKind
  grantedById  String         // FK al TeamMember (CSL/SUPER_ADMIN) que compartió
  grantedBy    TeamMember     @relation("GrantedBy", fields: [grantedById], references: [id], onDelete: Restrict)
  reason       String?        @db.Text
  createdAt    DateTime       @default(now())

  // NULLs son distintos en PG → la unicidad real la garantizan los scripts esta
  // vuelta (no hay UI). Se reforzará con constraint parcial cuando llegue la UI.
  @@unique([clientId, teamMemberId, targetRole])
  @@index([teamMemberId])
  @@index([clientId])
}

enum AssignmentKind {
  GRANT
  REVOKE
}

// ─── ExecutionLog ─────────────────────────────────────────────────────────────

model ExecutionLog {
  id               String          @id @default(cuid())
  implementationId String
  implementation   Implementation  @relation(fields: [implementationId], references: [id], onDelete: Cascade)
  action           String
  resource         String
  status           ExecutionStatus
  details          Json
  createdAt        DateTime        @default(now())
}

// ============================================
// KNOWLEDGE BASE — Documentos de conocimiento
// ============================================

enum KnowledgeType {
  PROCESS       // Procesos operativos (cómo ejecutar una fase, cadencia semanal, etc.)
  METHODOLOGY   // Metodologías (Inbound, Loop Framework, gestión del cambio)
  HUBSPOT_SPEC  // Features y specs de HubSpot (releases, capacidades, limitaciones)
  BEST_PRACTICE // Mejores prácticas descubiertas en proyectos anteriores
  TEMPLATE      // Plantillas reutilizables (agendas, estructuras de informes, etc.)
}

enum KnowledgeStatus {
  DRAFT     // En borrador, no visible para agentes
  PUBLISHED // Activo, los agentes lo consultan
  ARCHIVED  // Obsoleto, no se consulta pero se conserva
}

enum TagCategory {
  SERVICE      // Servicio: loop_marketing, loop_sales, loop_service, proyecto_temporal
  STAGE        // Etapa: diagnostico, mvp, adopcion
  SUBSTAGE     // Subetapa: analisis_inicial, funnel, mapeo, kickoff, piloto, escalamiento, etc.
  DOMAIN       // Dominio funcional: marketing, sales, service, cross_department
  HUBSPOT_AREA // Área de HubSpot: crm, automation, reporting, breeze, workflows, pipelines
  TOPIC        // Tema libre: gestion_cambio, liderazgo, onboarding, data_quality, etc.
}

model KnowledgeDocument {
  id      String          @id @default(cuid())
  type    KnowledgeType
  status  KnowledgeStatus @default(DRAFT)

  title   String
  summary String?   // Resumen corto para listados y contexto rápido de agentes
  content String    @db.Text // Contenido completo en Markdown

  version Int @default(1)

  // Autoría (sin modelo User — usamos email de sesión)
  createdByEmail String?
  updatedByEmail String?

  tags       KnowledgeTag[]
  embeddings KnowledgeEmbedding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
  @@index([createdAt])
}

// ============================================
// SISTEMA DE TAGS — Taxonomía para filtrado
// ============================================

model KnowledgeTag {
  id       String      @id @default(cuid())
  category TagCategory
  value    String      // Ej: "loop_marketing"
  label    String      // Ej: "Loop Marketing"

  documents KnowledgeDocument[]

  @@unique([category, value])
  @@index([category])
}

// ============================================
// EMBEDDINGS — Para búsqueda semántica futura
// ============================================

model KnowledgeEmbedding {
  id         String            @id @default(cuid())
  documentId String
  document   KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  chunkIndex Int    @default(0)
  chunkText  String @db.Text

  // El vector se agrega vía SQL directo en Supabase (pgvector, 1024 dims)
  // ALTER TABLE "KnowledgeEmbedding" ADD COLUMN embedding vector(1024);

  createdAt DateTime @default(now())

  @@index([documentId])
}

// ── FirefliesSession — caché local de sesiones de Fireflies y Google Meet ─────

model FirefliesSession {
  id             String    @id
  title          String
  date           DateTime
  duration       Float     @default(0)
  participants   String[]
  summary        Json?
  transcript     String?   @db.Text
  enrichedAt     DateTime?           // cuándo se trajo transcript/summary (null = pendiente)
  syncedAt       DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  source         String    @default("google_meet") // "google_meet" (Fireflies eliminado; "fireflies" solo en filas históricas)
  googleDocId    String?               // ID del Google Doc de la reunión (Meet)
  googleEventId  String?               // ID del evento de Google Calendar (Meet)
  organizerEmail String?               // Email del organizador (para impersonación en enriquecimiento)
  manualClientId String?               // override manual del matching automático de cliente
  resolvedClientId String?             // PERF #1: cliente resuelto (materializado de categorizeSession) para "última actividad"/bookends sin cargar todas las sesiones. Re-resuelto en write/override/mutación de Client.

  // F5: sub-topics detectados por IA (lead-scoring, workflow-builder, etc.).
  // Lista canónica viva en lib/sessions/topic-vocabulary.ts y se sesga por
  // serviceType del proyecto primario.
  detectedTopics String[] @default([])

  // Relaciones del ciclo de reunión (minuta post + acciones derivadas)
  minute      SessionMinute?
  actionItems ActionItem[]
  projects    SessionProject[]

  // Índices para los queries principales:
  //   /sessions: findMany({ where: { date: { lt: now } }, orderBy: { date: desc } })
  //   override manual: filtros por manualClientId al matchear sesiones
  // Sin esto, Postgres hace seq scan + sort en cada render.
  @@index([date(sort: Desc)])
  @@index([manualClientId])
  @@index([resolvedClientId, date(sort: Desc)])
}

// ─── Ciclo de reunión: Minuta + ActionItems ──────────────────────────────────
// Estos modelos encarnan el flujo del CSE:
//   1. La reunión sucede (FirefliesSession con transcript)
//   2. El agente Post-sesión genera SessionMinute (DRAFT) + ActionItems
//   3. El CSE revisa la minuta (DRAFT → REVIEWED) y trabaja las acciones
//   4. La siguiente sesión vuelve a iterar

enum MinuteStatus {
  DRAFT     // generada por agente, esperando revisión del CSE
  REVIEWED  // CSE la revisó y aceptó sin cambios
  EDITED    // CSE la editó manualmente (también implica aceptada)
}

enum ActionStatus {
  PENDING
  IN_PROGRESS
  BLOCKED
  DONE
}

model SessionMinute {
  id        String           @id @default(cuid())
  sessionId String           @unique
  session   FirefliesSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Síntesis estructurada de la reunión
  summary    String  @db.Text       // resumen ejecutivo (1-2 párrafos)
  agreements Json?                  // [{ text, source? }]
  decisions  Json?                  // [{ text, rationale? }]
  risks      Json?                  // [{ text, severity? "low" | "med" | "high" }]
  topics     Json?                  // ["bullet 1", "bullet 2"]

  // Estado y trazabilidad
  status               MinuteStatus @default(DRAFT)
  generatedByAgentRunId String?     // FK suave (no cascade) al AgentRun que la creó
  reviewedAt           DateTime?
  reviewedByEmail      String?      // email del CSE que aceptó/editó

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model ActionItem {
  id   String @id @default(cuid())
  text String @db.Text

  clientId  String
  client    Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sessionId String?
  session   FirefliesSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  // Asignación y plazos
  ownerEmail String?
  dueDate    DateTime?
  status     ActionStatus @default(PENDING)
  done       Boolean      @default(false)

  // Trazabilidad de origen
  source                String? // "agent:post-session" | "agent:sales-analysis" | "manual" | "legacy" | "agent:client-analyze"
  generatedByAgentRunId String? // FK suave al AgentRun que lo creó

  // Soft-delete: borrar una tarea NO la elimina; setea deletedAt para que siga
  // visible en el "Histórico" del modal de pendientes (tareas hechas o borradas).
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, done])
  @@index([projectId, done])
  @@index([projectId, deletedAt])
  @@index([sessionId])
  @@index([ownerEmail, done])
  @@index([dueDate])
}

// ─── SessionProject — pivote N:N entre FirefliesSession y Project ─────────────
// Una sesión puede tocar múltiples proyectos del mismo cliente (ej. una reunión
// de "alineación general" que cubre marketing + ventas). isPrimary indica el
// proyecto principal donde se ve la minuta/cards/acciones por defecto.
// source: "agent" (clasificador automático) | "manual" (CSE) | "legacy" (migración).

model SessionProject {
  id        String           @id @default(cuid())
  sessionId String
  session   FirefliesSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  projectId String
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  isPrimary  Boolean @default(false)
  source     String  @default("agent") // "agent" | "manual" | "legacy"
  confidence Float?                    // 0..1, solo si source="agent"
  rationale  String? @db.Text          // por qué la IA lo asignó
  // Override del humano para el HANDOFF, independiente del filtro automático (título de
  // venta/handoff/kickoff o Ventas en la sala): null = seguí la regla; true = forzá
  // incluir (agregada a mano desde el pop-up); false = forzá excluir (la "X" del panel).
  handoffOverride Boolean?

  generatedByAgentRunId String? // FK suave al AgentRun del clasificador
  createdAt             DateTime @default(now())

  @@unique([sessionId, projectId])
  @@index([projectId, isPrimary])
  @@index([sessionId])
}

// ─── Snapshot del análisis de participantes por proyecto (F5) ─────────────────
// Generado periódicamente por agent-participants-analyzer. Sobreescribible.

model ProjectParticipantSnapshot {
  id         String   @id @default(cuid())
  projectId  String   @unique
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  stats      Json     // { clientSponsorAttendance, lastSeenByRole, averageHeadcount, ... }
  sessionsAnalyzed Int @default(0)
  generatedByAgentRunId String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Canvas Suggestions (aprobación de cambios al Client Canvas) ─────────────

model CanvasSuggestion {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agentRunId String?
  section    String   // key del canvas: "perfil", "stakeholders", etc.
  field      String?  // campo específico dentro de la sección (para sugerencias granulares)
  current    Json?    // valor actual de la sección al momento de la sugerencia
  suggested  Json     // valor sugerido por el agente
  suggestedValue String? @db.Text // valor sugerido como texto (alternativa a JSON)
  status     String   @default("pending") // pending | accepted | rejected
  source     String?  // de dónde viene: "run:ID", "fireflies:TITLE", "manual"
  sourceLabel String? // label legible: "Análisis inicial · 24 mar", "Sesión kickoff UCI"
  createdAt  DateTime @default(now())

  @@index([clientId, status])
}

// ─── SessionCategory — agrupación administrable de sesiones por dominio ──────
// Sirve para categorizar sesiones de Google Meet / Fireflies por el dominio
// de sus participantes (ej: "Interna" = @smarteamcr.com, "Partner HubSpot" = @hubspot.com).
// Los matching de Client.emailDomains tienen prioridad — esto categoriza el RESTO.

model SessionCategory {
  id        String   @id @default(cuid())
  name      String   @unique              // "Interna", "Partner HubSpot", "Partner AtomChat"
  slug      String   @unique              // "interna", "partner-hubspot" (URL-safe)
  domains   String[]                      // ["smarteamcr.com"], ["hubspot.com", "hubspotcr.com"]
  kind      String   @default("custom")   // "internal" | "partner" | "custom" — semántica para UI/orden
  color     String?                       // hex (#94A3B8) para tag visual en sidebar
  order     Int      @default(0)          // orden de aparición en sidebar
  isDefault Boolean  @default(false)      // las default no se pueden eliminar (sí editar)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════════════════
// MARKETING + CONTENIDO — módulo single-tenant (equipo Smarteam; NADA cuelga de
// Client). Insumos curados (ICP, personas, pilares, fuentes, voz) + posts de
// inspiración scrapeados de LinkedIn + salidas del agente (ideas/campañas/
// sugerencias de pilar) + corridas (ingesta/generación) + lock del cron semanal.
// ═══════════════════════════════════════════════════════════════════════════════

enum IcpSection {
  FIRMOGRAFICA_DESCRIPTOR // Firmográfica — descriptores
  FIRMOGRAFICA_INDUSTRIA  // Firmográfica — industrias con validación real
  BEHAVIORAL_REVENUE      // Behavioral — revenue intelligence
  BEHAVIORAL_CANALES      // Behavioral — canales y comportamiento
  BEHAVIORAL_ORG          // Behavioral — la organización
  BEHAVIORAL_DECISION     // Behavioral — estructura de decisión
  SIGNAL_ANTI             // Señales — Anti-ICP
  SIGNAL_FUERTE           // Señales fuertes
  SIGNAL_MEDIA            // Señales medias
  SIGNAL_DEBIL            // Señales débiles
}

enum PillarOrigin {
  HUMAN // creado a mano por el equipo
  AGENT // nació de una PillarSuggestion aprobada
}

enum MarketingApprovalStatus {
  PENDING
  APPROVED
  DISCARDED
}

enum CampaignChannel {
  GOOGLE_SEARCH
  PAID_SOCIAL
  DISPLAY
  OTHER
}

enum MarketingRunKind {
  INGEST   // solo scraping de fuentes
  GENERATE // solo agente de generación (sobre lo guardado)
  CHAIN    // ingesta → generación (si hubo posts nuevos)
}

enum MarketingRunTrigger {
  MANUAL // CTA en /contenido
  CRON   // viernes 6:00 America Costa Rica
}

enum MarketingRunStatus {
  RUNNING
  DONE
  ERROR
}

// Config singleton del módulo (id="marketing"): voz de marca + lock del cron.
model MarketingSettings {
  id              String    @id @default("marketing")
  brandVoice      String    @db.Text // voz/posicionamiento (markdown) — editable en /marketing/voz
  lastCronRunAt   DateTime? // nullable porque nunca corrió — display en /contenido
  lastCronDateKey String?   // nullable ídem — "YYYY-MM-DD" (día CR) del último disparo; claim atómico anti-doble-fire
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Ítem del ICP (migrado del hardcode de app/icp/ICPSection.tsx). 1 fila = 1 bullet.
model IcpItem {
  id        String     @id @default(cuid())
  section   IcpSection
  label     String     @db.Text
  order     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([section, order])
}

// Buyer persona — insumo curado que alimenta al agente de generación.
model BuyerPersona {
  id          String   @id @default(cuid())
  name        String
  role        String?  // nullable porque el cargo/segmento puede cargarse después
  description String   @db.Text // quién es, contexto (markdown)
  pains       String?  @db.Text // nullable porque se carga incremental
  goals       String?  @db.Text // nullable ídem
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
}

// Pilar de contenido (tema/enfoque). Los AGENT nacen al aprobar una PillarSuggestion.
model ContentPillar {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?      @db.Text // nullable porque un pilar puede ser solo un nombre al alta
  origin      PillarOrigin @default(HUMAN)
  active      Boolean      @default(true)
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  ideas      ContentIdea[]
  suggestion PillarSuggestion?
}

// Fuente de inspiración: perfil público de LinkedIn (se scrapea vía InspirationProvider).
model InspirationSource {
  id             String    @id @default(cuid())
  profileUrl     String    @unique
  label          String?   // nullable porque al alta a veces solo hay URL
  active         Boolean   @default(true)
  lastFetchedAt  DateTime? // nullable hasta la primera ingesta
  lastFetchError String?   @db.Text // nullable = última ingesta OK; error del provider si falló
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  posts InspirationPost[]

  @@index([active])
}

// Post scrapeado de una fuente. Dedup por externalId. "Archivado" NO es campo:
// la generación filtra postedAt >= hoy-3 meses; lo viejo queda fuera del contexto.
model InspirationPost {
  id           String            @id @default(cuid())
  sourceId     String
  source       InspirationSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  externalId   String            @unique // id/URN del post en LinkedIn — DEDUP KEY
  url          String?           // nullable porque algunos actors no devuelven permalink
  authorName   String?           // nullable ídem
  text         String            @db.Text
  likeCount    Int               @default(0)
  commentCount Int               @default(0)
  repostCount  Int               @default(0)
  hasImage     Boolean           @default(false)
  postedAt     DateTime
  fetchedAt    DateTime          @default(now())

  ideaSources ContentIdeaSource[]

  @@index([postedAt])
  @@index([sourceId, postedAt])
}

// Corrida del módulo (ingesta/generación/cadena). Modelo PROPIO: AgentRun exige
// clientId (NOT NULL) y esto es single-tenant. Trazabilidad estilo regla 6.5.
model MarketingRun {
  id                     String              @id @default(cuid())
  kind                   MarketingRunKind
  trigger                MarketingRunTrigger @default(MANUAL)
  status                 MarketingRunStatus  @default(RUNNING)
  phase                  String?   // nullable cuando terminó — copy de progreso ("ingesta 3/8")
  newPostsCount          Int?      // nullable hasta terminar la ingesta — posts NUEVOS post-dedup
  fetchedPostsCount      Int?      // total traído del provider
  sourcesOkCount         Int?
  sourcesErrorCount      Int?
  contentIdeasCount      Int?      // nullable hasta terminar la generación
  campaignIdeasCount     Int?
  pillarSuggestionsCount Int?
  error                  String?   @db.Text // mensaje REAL cuando status=ERROR
  rawOutput              String?   @db.Text // JSON crudo de Claude (backup/debug)
  startedByEmail         String?   // nullable porque el CRON no tiene usuario
  createdAt              DateTime  @default(now())
  finishedAt             DateTime?

  contentIdeas      ContentIdea[]
  campaignIdeas     CampaignIdea[]
  pillarSuggestions PillarSuggestion[]

  @@index([status, createdAt])
  @@index([kind, createdAt])
}

// Idea de contenido generada — salida NO-CRUD: se revisa y se PODA (DELETE).
// Registro estructurado por campo para migrar a HubSpot copiando campo a campo.
model ContentIdea {
  id                  String         @id @default(cuid())
  runId               String?        // nullable porque la idea sobrevive si se borra la corrida
  run                 MarketingRun?  @relation(fields: [runId], references: [id], onDelete: SetNull)
  pillarId            String?        // nullable porque puede referir a un pilar SUGERIDO aún no aprobado
  pillar              ContentPillar? @relation(fields: [pillarId], references: [id], onDelete: SetNull)
  suggestedPillarName String?        // nullable — nombre del pilar NUEVO propuesto; se linkea al aprobar
  title               String
  copy                String         @db.Text // copy listo para red social
  imageConcept        String         @db.Text // descripción TEXTUAL del concepto de imagen (no se genera)
  createdAt           DateTime       @default(now())

  sources ContentIdeaSource[]

  @@index([pillarId])
  @@index([createdAt])
}

// Pivote idea ↔ posts que la inspiraron (el agente nunca inventa fuentes).
model ContentIdeaSource {
  id     String          @id @default(cuid())
  ideaId String
  idea   ContentIdea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  postId String
  post   InspirationPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([ideaId, postId])
}

// Idea de campaña (PPC / Google Search) — aprobable / descartable.
model CampaignIdea {
  id          String                  @id @default(cuid())
  runId       String?                 // nullable porque sobrevive a la corrida
  run         MarketingRun?           @relation(fields: [runId], references: [id], onDelete: SetNull)
  title       String
  channel     CampaignChannel
  description String                  @db.Text // objetivo, audiencia, ángulo, keywords si aplica
  status      MarketingApprovalStatus @default(PENDING)
  reviewedAt  DateTime? // nullable hasta aprobar/descartar
  createdAt   DateTime  @default(now())

  @@index([status, createdAt])
}

// Sugerencia de pilar NUEVO del agente. PENDING → approve (crea ContentPillar) / discard.
model PillarSuggestion {
  id               String                  @id @default(cuid())
  runId            String?                 // nullable porque sobrevive a la corrida
  run              MarketingRun?           @relation(fields: [runId], references: [id], onDelete: SetNull)
  name             String
  description      String?                 @db.Text
  rationale        String?                 @db.Text // evidencia del agente (posts/insumos que lo motivan)
  status           MarketingApprovalStatus @default(PENDING)
  approvedPillarId String?                 @unique // nullable hasta aprobar — FK al pilar creado
  approvedPillar   ContentPillar?          @relation(fields: [approvedPillarId], references: [id], onDelete: SetNull)
  reviewedAt       DateTime?
  createdAt        DateTime                @default(now())

  @@index([status])
}
