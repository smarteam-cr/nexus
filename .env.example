# Base de datos (Supabase PostgreSQL)
DATABASE_URL=""

# Supabase Auth (mismo proyecto que DATABASE_URL — vincula auth.users con AppUser)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""  # admin key, server-only — para operaciones que bypasean RLS

# Supabase Storage (bucket "client-documents" para archivos subidos).
# Si SUPABASE_URL/SUPABASE_SECRET_KEY no están, lib/storage/client.ts cae a
# NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY (el proyecto principal).
# Definir estas SOLO si el Storage vive en un proyecto Supabase distinto.
SUPABASE_URL=""          # opcional — fallback a NEXT_PUBLIC_SUPABASE_URL
SUPABASE_SECRET_KEY=""   # opcional — fallback a SUPABASE_SERVICE_ROLE_KEY

# HubSpot OAuth
HUBSPOT_CLIENT_ID=""
HUBSPOT_CLIENT_SECRET=""
HUBSPOT_REDIRECT_URI="http://localhost:3000/api/auth/callback"

# Google Workspace (Service Account + Domain-Wide Delegation).
# Usado para: sync de Google Meet/Calendar, lectura de Gemini Notes, y lectura
# de archivos de Drive (Docs/Slides/Sheets) cuando un CSE pega un link.
GOOGLE_SERVICE_ACCOUNT_KEY=""  # JSON completo de la service account (client_email + private_key)
GOOGLE_ADMIN_EMAIL=""          # super admin del dominio para impersonación DWD (Directory API)

# Anthropic (Claude API)
ANTHROPIC_API_KEY=""

# App
APP_URL="http://localhost:3000"

# Fireflies
FIREFLIES_API_KEY=""

# Data Lake (Supabase secundario)
DATA_LAKE_URL=""
DATA_LAKE_PUBLISHABLE_KEY=""
DATA_LAKE_SECRET_KEY=""
